<Window x:Class="StatsClient.MVVM.View.AddCustomerSuggestionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StatsClient.MVVM.View"
        xmlns:viewmodel="clr-namespace:StatsClient.MVVM.ViewModel"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        Title="AddCustomerSuggestionsWindow"
        Height="200"
        Width="620"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowState="Normal"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource TransparentBrush}"
        Foreground="{DynamicResource AddCustomerLabelForeground}">

    <Window.DataContext>
        <viewmodel:AddCustomerSuggestionsViewModel />
    </Window.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <Style x:Key="AddCustomerCloseButton"
                   TargetType="Button">
                <Setter Property="Background"
                        Value="{DynamicResource TransparentBrush}" />
                <Setter Property="BorderThickness"
                        Value="0" />
                <Setter Property="Cursor"
                        Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="{StaticResource SchemeColor_DE766B}"
                                            TargetName="Border" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="AddCustomerFieldTextBox"
                   TargetType="TextBox">
                <Setter Property="Background"
                        Value="{DynamicResource AddCustomerFieldBackground}" />
                <Setter Property="Foreground"
                        Value="{DynamicResource AddCustomerFieldForeground}" />
                <Setter Property="BorderBrush"
                        Value="{DynamicResource AddCustomerFieldBorder}" />
                <Setter Property="BorderThickness"
                        Value="1" />
                <Setter Property="Padding"
                        Value="6,2" />
            </Style>

            <Style x:Key="AddCustomerActionButtonBase"
                   TargetType="Button">
                <Setter Property="BorderThickness"
                        Value="1" />
                <Setter Property="Padding"
                        Value="10,4" />
                <Setter Property="FontSize"
                        Value="13" />
                <Setter Property="Cursor"
                        Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="AddCustomerAddButton"
                   TargetType="Button"
                   BasedOn="{StaticResource AddCustomerActionButtonBase}">
                <Setter Property="Background"
                        Value="{DynamicResource AddCustomerConfirmButtonBackground}" />
                <Setter Property="Foreground"
                        Value="{DynamicResource AddCustomerConfirmButtonForeground}" />
                <Setter Property="BorderBrush"
                        Value="{DynamicResource AddCustomerConfirmButtonBorder}" />
            </Style>

            <Style x:Key="AddCustomerCancelButton"
                   TargetType="Button"
                   BasedOn="{StaticResource AddCustomerActionButtonBase}">
                <Setter Property="Background"
                        Value="{DynamicResource AddCustomerCancelButtonBackground}" />
                <Setter Property="Foreground"
                        Value="{DynamicResource AddCustomerCancelButtonForeground}" />
                <Setter Property="BorderBrush"
                        Value="{DynamicResource AddCustomerCancelButtonBorder}" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="8,8,4,8"
            BorderThickness="0.5"
            BorderBrush="{DynamicResource BlackColor}"
            Background="{DynamicResource PrimaryDarkColor}"
            ClipToBounds="True">
        <Border CornerRadius="8,8,8,8"
                BorderThickness="0.5"
                Margin="10"
                BorderBrush="{DynamicResource BlackColor}"
                Background="{DynamicResource PrimaryColor}"
                ClipToBounds="True">
            <Grid Margin="7">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>


                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="96" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Customer Name:"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Margin="0,0,8,6"
                               Foreground="{DynamicResource AddCustomerLabelForeground}" />

                    <TextBox Grid.Column="1"
                             Grid.Row="0"
                             FontSize="16"
                             Margin="0,0,0,6"
                             Style="{StaticResource AddCustomerFieldTextBox}"
                             Text="{Binding CustomerName}"
                             Height="28"
                             IsReadOnly="True" />

                    <Button Content="╳"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Right"
                            Width="32"
                            Height="26"
                            FontSize="16"
                            Grid.Column="2"
                            Foreground="{DynamicResource AddCustomerTitleForeground}"
                            Command="{Binding CloseWindowCommand}"
                            Style="{StaticResource AddCustomerCloseButton}" />

                    <TextBlock Text="New Name:"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Margin="0,0,8,6"
                               FontSize="14"
                               Grid.Row="1"
                               Foreground="{DynamicResource AddCustomerLabelForeground}" />

                    <TextBox Grid.Column="1"
                             Grid.Row="1"
                             FontSize="16"
                             Margin="0,0,0,6"
                             Style="{StaticResource AddCustomerFieldTextBox}"
                             Text="{Binding NewName}"
                             Height="28" />

                    <TextBlock Text="Registered Names:"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Right"
                               Margin="0,4,8,0"
                               FontSize="14"
                               Grid.Row="2"
                               Foreground="{DynamicResource AddCustomerLabelForeground}" />

                    <ListBox Grid.Column="1"
                             Grid.Row="2"
                             Background="{DynamicResource AddCustomerListBackground}"
                             BorderBrush="{DynamicResource AddCustomerFieldBorder}"
                             BorderThickness="1"
                             Foreground="{DynamicResource AddCustomerFieldForeground}"
                             ItemsSource="{Binding CustomerSuggestionsList}" />

                    <StackPanel Grid.Column="2"
                                Grid.Row="2"
                                VerticalAlignment="Bottom"
                                Margin="8,0,0,0">
                        <Button Content="Add"
                                Height="28"
                                Margin="0,0,0,6"
                                Style="{StaticResource AddCustomerAddButton}"
                                Command="{Binding AddCommand}" />

                        <Button Content="Cancel"
                                Height="28"
                                Style="{StaticResource AddCustomerCancelButton}"
                                Command="{Binding CloseWindowCommand}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
