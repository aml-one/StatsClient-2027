<UserControl x:Class="StatsClient.MVVM.View.ThreeShapeFilterPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="470">
    <Grid ClipToBounds="True">
        <Rectangle Opacity="0.07"
                   IsHitTestVisible="False">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0"
                                     EndPoint="0,1">
                    <GradientStop Color="{DynamicResource AccentColor_Cl}"
                                  Offset="0" />
                    <GradientStop Color="{DynamicResource SchemeColor_0034D9F5_Cl}"
                                  Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Grid Margin="0,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,10"
                    Padding="12,8"
                    CornerRadius="10"
                    BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,0">
                        <GradientStop Color="{DynamicResource SchemeColor_FF1A2836_Cl}"
                                      Offset="0" />
                        <GradientStop Color="{DynamicResource SchemeColor_FF243447_Cl}"
                                      Offset="0.55" />
                        <GradientStop Color="{DynamicResource SchemeColor_FF2A3A52_Cl}"
                                      Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,0">
                        <GradientStop Color="{DynamicResource ImmersiveFocusRing_Cl}"
                                      Offset="0" />
                        <GradientStop Color="{DynamicResource SchemeColor_44D6B97A_Cl}"
                                      Offset="1" />
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Grid>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Ellipse Width="8"
                                 Height="8"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="{DynamicResource SchemeColor_FF9AF4FF_Cl}"
                                                  Offset="0" />
                                    <GradientStop Color="{DynamicResource AccentColor_Cl}"
                                                  Offset="1" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="FILTER CASES"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource ImmersiveFilterButtonHoverGradientEnd}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="Quick access"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="10"
                               Foreground="{DynamicResource SchemeColor_88A8B8C8}" />
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource FilterSectionReveal1}">
                            <StackPanel>
                                <TextBlock Text="Recent"
                                           Style="{StaticResource FilterSectionHeaderText}" />
                                <Button x:Name="btnMyRecent30"
                                        Style="{StaticResource ImmersiveFilterButton}"
                                        Margin="0,0,0,3"
                                        Command="{Binding FilterMenuItemCommand}"
                                        CommandParameter="MyRecent30">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Images/FilterIcons/001_OrdersByDate22x22.png"
                                               Width="18"
                                               Height="18"
                                               Margin="0,0,8,0" />
                                        <TextBlock Text="My Last 30 Orders"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="btnMyRecent"
                                        Style="{StaticResource ImmersiveFilterButton}"
                                        Command="{Binding FilterMenuItemCommand}"
                                        CommandParameter="MyRecent">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Images/FilterIcons/001_OrdersByDate22x22.png"
                                               Width="18"
                                               Height="18"
                                               Margin="0,0,8,0" />
                                        <TextBlock Text="My Recent (long list)"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource FilterSectionReveal2}">
                            <StackPanel>
                                <TextBlock Text="By Date"
                                           Style="{StaticResource FilterSectionHeaderText}" />
                                <Button Style="{StaticResource ImmersiveFilterButton}"
                                        Margin="0,0,0,3"
                                        Command="{Binding FilterMenuItemCommand}"
                                        CommandParameter="Yesterday">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Images/FilterIcons/002_OrdersByDateToday22x22.png"
                                               Width="18"
                                               Height="18"
                                               Margin="0,0,8,0" />
                                        <TextBlock Text="Yesterday"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ImmersiveFilterButton}"
                                        Margin="0,0,0,3"
                                        Command="{Binding FilterMenuItemCommand}"
                                        CommandParameter="LastTwoDays">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Images/FilterIcons/003_OrdersByDateLastTwoDays22x22.png"
                                               Width="18"
                                               Height="18"
                                               Margin="0,0,8,0" />
                                        <TextBlock Text="Last Two Days"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ImmersiveFilterButton}"
                                        Margin="0,0,0,3"
                                        Command="{Binding FilterMenuItemCommand}"
                                        CommandParameter="ThisWeek">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Images/FilterIcons/004_OrdersByDateLastWeek22x22.png"
                                               Width="18"
                                               Height="18"
                                               Margin="0,0,8,0" />
                                        <TextBlock Text="This Week"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ImmersiveFilterButton}"
                                        Margin="0,0,0,3"
                                        Command="{Binding FilterMenuItemCommand}"
                                        CommandParameter="ThisAndLastWeek">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Images/FilterIcons/005_OrdersByDateLastTwoWeeks22x22.png"
                                               Width="18"
                                               Height="18"
                                               Margin="0,0,8,0" />
                                        <TextBlock Text="This and Last Week"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ImmersiveFilterButton}"
                                        Command="{Binding FilterMenuItemCommand}"
                                        CommandParameter="LastMonth">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Images/FilterIcons/005_OrdersByDateLastTwoWeeks22x22.png"
                                               Width="18"
                                               Height="18"
                                               Margin="0,0,8,0" />
                                        <TextBlock Text="Last 30 days"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource FilterSectionReveal3}">
                            <StackPanel>
                                <TextBlock Text="By Type"
                                           Style="{StaticResource FilterSectionHeaderText}" />
                                <Button Style="{StaticResource ImmersiveFilterButton}"
                                        Margin="0,0,0,3"
                                        Command="{Binding FilterMenuItemCommand}"
                                        CommandParameter="DigitalModels">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Images/FilterIcons/22x22_DigitalModel.png"
                                               Width="18"
                                               Height="18"
                                               Margin="0,0,8,0" />
                                        <TextBlock Text="All Digital Models"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ImmersiveFilterButton}"
                                        Margin="0,0,0,3"
                                        Command="{Binding FilterMenuItemCommand}"
                                        CommandParameter="ImpressionAll">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Images/FilterIcons/22x22_3DBitePlate.png"
                                               Width="18"
                                               Height="18"
                                               Margin="0,0,8,0" />
                                        <TextBlock Text="Impression cases"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ImmersiveFilterButton}"
                                        Margin="0,0,0,3"
                                        Command="{Binding FilterMenuItemCommand}"
                                        CommandParameter="ModelAll">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Images/FilterIcons/22x22_preparation.png"
                                               Width="18"
                                               Height="18"
                                               Margin="0,0,8,0" />
                                        <TextBlock Text="Stone model cases"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ImmersiveFilterButton}"
                                        Command="{Binding FilterMenuItemCommand}"
                                        CommandParameter="DigitalAll">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Images/FilterIcons/025_OrderStatusScannedTrios22x22.png"
                                               Width="18"
                                               Height="18"
                                               Margin="0,0,8,0" />
                                        <TextBlock Text="Digital Impressions"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource FilterSectionReveal4}">
                        <StackPanel>
                            <TextBlock Text="By Status"
                                       Style="{StaticResource FilterSectionHeaderText}" />
                            <Button Style="{StaticResource ImmersiveFilterButton}"
                                    Margin="0,0,0,3"
                                    Command="{Binding FilterMenuItemCommand}"
                                    CommandParameter="NeverSentAbutments">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Images/FilterIcons/notSentOut_28.png"
                                           Width="18"
                                           Height="18"
                                           Margin="0,0,8,0" />
                                    <TextBlock Text="Waiting for Send"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ImmersiveFilterButton}"
                                    Margin="0,0,0,3"
                                    Command="{Binding FilterMenuItemCommand}"
                                    CommandParameter="Created">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Images/FilterIcons/007_OrderStatusCreated22x22.png"
                                           Width="18"
                                           Height="18"
                                           Margin="0,0,8,0" />
                                    <TextBlock Text="Created / entered cases"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ImmersiveFilterButton}"
                                    Margin="0,0,0,3"
                                    Command="{Binding FilterMenuItemCommand}"
                                    CommandParameter="Scanned">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Images/FilterIcons/009_OrderStatusScanned22x22.png"
                                           Width="18"
                                           Height="18"
                                           Margin="0,0,8,0" />
                                    <TextBlock Text="Scanned Cases"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ImmersiveFilterButton}"
                                    Margin="0,0,0,3"
                                    Command="{Binding FilterMenuItemCommand}"
                                    CommandParameter="ImpressionScans">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Images/FilterIcons/22x22_3DBitePlate.png"
                                           Width="18"
                                           Height="18"
                                           Margin="0,0,8,0" />
                                    <TextBlock Text="Scanned cases (impressions)"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ImmersiveFilterButton}"
                                    Margin="0,0,0,3"
                                    Command="{Binding FilterMenuItemCommand}"
                                    CommandParameter="ModelScans">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Images/FilterIcons/22x22_preparation.png"
                                           Width="18"
                                           Height="18"
                                           Margin="0,0,8,0" />
                                    <TextBlock Text="Scanned cases (model)"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ImmersiveFilterButton}"
                                    Margin="0,0,0,3"
                                    Command="{Binding FilterMenuItemCommand}"
                                    CommandParameter="DigitalScans">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Images/FilterIcons/025_OrderStatusScannedTrios22x22.png"
                                           Width="18"
                                           Height="18"
                                           Margin="0,0,8,0" />
                                    <TextBlock Text="Received cases (digital scans)"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ImmersiveFilterButton}"
                                    Margin="0,0,0,3"
                                    Command="{Binding FilterMenuItemCommand}"
                                    CommandParameter="Designed">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Images/FilterIcons/012_OrderStatusModelling22x22.png"
                                           Width="18"
                                           Height="18"
                                           Margin="0,0,8,0" />
                                    <TextBlock Text="Designed cases"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ImmersiveFilterButton}"
                                    Margin="0,0,0,3"
                                    Command="{Binding FilterMenuItemCommand}"
                                    CommandParameter="Designing">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Images/FilterIcons/psModelling.png"
                                           Width="18"
                                           Height="18"
                                           Margin="0,0,8,0" />
                                    <TextBlock Text="Design in progress"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ImmersiveFilterButton}"
                                    Margin="0,0,0,3"
                                    Command="{Binding FilterMenuItemCommand}"
                                    CommandParameter="Sent">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Images/FilterIcons/028_OrdersSent22x22.png"
                                           Width="18"
                                           Height="18"
                                           Margin="0,0,8,0" />
                                    <TextBlock Text="Sent to manufacturer"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ImmersiveFilterButton}"
                                    Margin="0,0,0,3"
                                    Command="{Binding FilterMenuItemCommand}"
                                    CommandParameter="Closed">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Images/FilterIcons/018_OrderStatusClosed22x22.png"
                                           Width="18"
                                           Height="18"
                                           Margin="0,0,8,0" />
                                    <TextBlock Text="Closed cases"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ImmersiveFilterButton}"
                                    Margin="0,0,0,3"
                                    Command="{Binding FilterMenuItemCommand}"
                                    CommandParameter="NotCheckedOut">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Images/FilterIcons/009_OrderStatusScanned22x22.png"
                                           Width="18"
                                           Height="18"
                                           Margin="0,0,8,0" />
                                    <TextBlock Text="Not Checked Out yet"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ImmersiveFilterButton}"
                                    Command="{Binding FilterMenuItemCommand}"
                                    CommandParameter="CheckedOut">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Images/FilterIcons/orders_CheckedOut.png"
                                           Width="18"
                                           Height="18"
                                           Margin="0,0,8,0" />
                                    <TextBlock Text="Checked Out cases"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>

        
    </Grid>
</UserControl>
