<Window x:Class="StatsClient.MVVM.View.EncodeIdentifyReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Encode Identifier Report"
        Height="520"
        Width="860"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        Background="#FFF6F7F9">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,8">
            <TextBlock Text="Copy/paste this report when Encode Identifier fails."
                       Foreground="#FF2A3A52"
                       FontSize="14"
                       FontWeight="SemiBold"
                       DockPanel.Dock="Left"/>
        </DockPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#FFCBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10">
            <TextBox x:Name="ReportTextBox"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     Background="White"
                     BorderThickness="0"
                     FontFamily="Consolas"
                     FontSize="12"
                     Foreground="#FF0F172A"/>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="CopyButton"
                    Width="110"
                    Height="30"
                    Margin="0,0,8,0"
                    Content="Copy"
                    Click="Copy_OnClick"/>
            <Button Width="110"
                    Height="30"
                    Content="Close"
                    IsDefault="True"
                    Click="Close_OnClick"/>
        </StackPanel>
    </Grid>
</Window>

