<UserControl x:Class="StatsClient.MVVM.View.ServerLogTabPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:converter="clr-namespace:StatsClient.MVVM.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1200">
    <UserControl.Resources>
        <converter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converter:ZeroToVisibleConverter x:Key="ZeroToVisibleConverter" />

        <Style x:Key="ServerLogSidebarTab" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource ImmersiveTextMuted}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabShell"
                                CornerRadius="7"
                                Margin="4,3"
                                Padding="12,11"
                                Background="{DynamicResource TransparentBrush}"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource TransparentBrush}"
                                Cursor="Hand">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabShell" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="{StaticResource ImmersiveGlassBackground_Cl}" Offset="0" />
                                            <GradientStop Color="{StaticResource ImmersiveAccentBlueLight_Cl}" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="TabShell" Property="BorderBrush" Value="{StaticResource ImmersiveCardShadow_Cl}" />
                                <Setter Property="Foreground" Value="{StaticResource ImmersiveAccentBlue}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabShell" Property="Background" Value="{StaticResource SchemeColor_66FFFFFF}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource TransparentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="168" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Margin="14,14,0,14"
                                    CornerRadius="9"
                                    Padding="6"
                                    BorderBrush="{DynamicResource ImmersiveGlassBorder}"
                                    BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="{DynamicResource SchemeColor_55FFFFFF_Cl}" Offset="0" />
                                        <GradientStop Color="{DynamicResource SchemeColor_33E0F2FE_Cl}" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TabPanel IsItemsHost="True"
                                          KeyboardNavigation.TabIndex="1"
                                          Background="{DynamicResource TransparentBrush}" />
                            </Border>

                            <Border Grid.Column="1"
                                    Margin="0,14,14,14"
                                    CornerRadius="9"
                                    Background="{DynamicResource TransparentBrush}">
                                <ContentPresenter ContentSource="SelectedContent"
                                                  KeyboardNavigation.TabIndex="2" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ServerLogSectionHeader" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="16,16,16,0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ServerLogListCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Margin" Value="16,10,16,0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Background" Value="{DynamicResource ImmersiveGlassBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ImmersiveGlassBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="{DynamicResource ImmersiveCardShadow_Cl}"
                                      BlurRadius="16"
                                      ShadowDepth="0"
                                      Opacity="0.12" />
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid ClipToBounds="True">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{DynamicResource ImmersiveGradientStart_Cl}" Offset="0" />
                <GradientStop Color="{DynamicResource ImmersiveGradientMid_Cl}" Offset="0.45" />
                <GradientStop Color="{DynamicResource ImmersiveGradientEnd_Cl}" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse Width="360"
                 Height="360"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,-80,-60,0"
                 Opacity="0.22"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="{DynamicResource ImmersiveOrbCyan_Cl}" Offset="0" />
                    <GradientStop Color="{DynamicResource ImmersiveOrbCyanTransparent_Cl}" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Ellipse Width="280"
                 Height="280"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Bottom"
                 Margin="-40,0,0,-40"
                 Opacity="0.18"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="{DynamicResource ImmersiveOrbPeach_Cl}" Offset="0" />
                    <GradientStop Color="{DynamicResource ImmersiveOrbPeachTransparent_Cl}" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <TabControl TabStripPlacement="Left"
                    BorderThickness="0"
                    Background="{DynamicResource TransparentBrush}"
                    Padding="0">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource ServerLogSidebarTab}" />
            </TabControl.Resources>

            <TabItem IsTabStop="False">
                <TabItem.Header>
                    <TextBlock Text="Import / Export"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource ServerLogSectionHeader}"
                            Background="{DynamicResource SchemeColor_FFD1FAE5}"
                            BorderBrush="{DynamicResource SchemeColor_FF86EFAC}">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <Path Data="M12,7 L12,15 M12,15 L8,11 M12,15 L16,11 M5,17 L19,17"
                                  Stroke="{DynamicResource ImmersiveSuccessText}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform"
                                  Width="18"
                                  Height="18"
                                  Margin="0,0,10,0" />
                            <TextBlock Text="Imported Orders History"
                                       Foreground="{DynamicResource SchemeColor_FF065F46}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Style="{StaticResource ServerLogListCard}">
                        <ListView Style="{StaticResource LvListViewImportHistory}"
                                  BorderThickness="0"
                                  ItemsSource="{Binding ImportedCasesList}"
                                  ItemContainerStyle="{StaticResource LvItemImportHistory}"
                                  AlternationCount="2"
                                  Padding="6" />
                    </Border>

                    <TextBlock Grid.Row="1"
                               Text="Nothing so far.."
                               Opacity="0.45"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="15"
                               FontStyle="Italic"
                               Foreground="{DynamicResource ImmersiveTextMuted}"
                               d:Visibility="Visible"
                               Visibility="{Binding ImportedCasesList.Count, Converter={StaticResource ZeroToVisibleConverter}}" />

                    <Border Grid.Row="2"
                            Height="1"
                            Margin="32,14"
                            Opacity="0.55">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="{DynamicResource SchemeColor_00CBD5E1_Cl}" Offset="0" />
                                <GradientStop Color="{DynamicResource ImmersiveInputBorder_Cl}" Offset="0.5" />
                                <GradientStop Color="{DynamicResource SchemeColor_00CBD5E1_Cl}" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <Border Grid.Row="3"
                            Style="{StaticResource ServerLogSectionHeader}"
                            Margin="16,8,16,0"
                            Background="{DynamicResource SchemeColor_FFEDE9FE}"
                            BorderBrush="{DynamicResource SchemeColor_FFC4B5FD}">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <Path Data="M12,17 L12,9 M12,9 L8,13 M12,9 L16,13 M5,7 L19,7"
                                  Stroke="{DynamicResource SchemeColor_FF7C3AED}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform"
                                  Width="18"
                                  Height="18"
                                  Margin="0,0,10,0" />
                            <TextBlock Text="Exported Orders History"
                                       Foreground="{DynamicResource SchemeColor_FF5B21B6}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="4"
                            Style="{StaticResource ServerLogListCard}"
                            Margin="16,10,16,16">
                        <ListView Style="{StaticResource LvListViewExportHistory}"
                                  BorderThickness="0"
                                  ItemsSource="{Binding ExportedCasesList}"
                                  ItemContainerStyle="{StaticResource LvItemExportHistory}"
                                  AlternationCount="2"
                                  Padding="6" />
                    </Border>

                    <TextBlock Grid.Row="4"
                               Text="Nothing here yet"
                               Opacity="0.45"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="15"
                               FontStyle="Italic"
                               Foreground="{DynamicResource ImmersiveTextMuted}"
                               d:Visibility="Visible"
                               Visibility="{Binding ExportedCasesList.Count, Converter={StaticResource ZeroToVisibleConverter}}" />
                </Grid>
            </TabItem>

            <TabItem IsTabStop="False"
                     x:Name="serverLogTab"
                     Visibility="{Binding ServerLogCanBeRead, Converter={StaticResource BoolToVisibilityConverter}}"
                     d:Visibility="Visible">
                <TabItem.Header>
                    <TextBlock Text="Services Log"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="16,16,16,0"
                            CornerRadius="9"
                            BorderBrush="{DynamicResource ImmersiveGlassBorder}"
                            BorderThickness="1"
                            Background="{DynamicResource ImmersiveInputBackground}"
                            ClipToBounds="True">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource ImmersiveCardShadow_Cl}"
                                              BlurRadius="18"
                                              ShadowDepth="0"
                                              Opacity="0.14" />
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    CornerRadius="9,9,0,0"
                                    Padding="14,10"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource SchemeColor_22CBD5E1}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{DynamicResource ImmersiveFilterButtonGlow_Cl}" Offset="0" />
                                        <GradientStop Color="{DynamicResource SchemeColor_11C4B5FD_Cl}" Offset="0.55" />
                                        <GradientStop Color="{DynamicResource SchemeColor_22FBCFE8_Cl}" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <Ellipse Width="7"
                                             Height="7"
                                             Margin="0,0,8,0"
                                             VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <RadialGradientBrush>
                                                <GradientStop Color="{DynamicResource SchemeColor_FF9AF4FF_Cl}" Offset="0" />
                                                <GradientStop Color="{DynamicResource AccentColor_Cl}" Offset="1" />
                                            </RadialGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock Text="LIVE SERVICES LOG"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource ImmersiveTextSecondary}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <wv2:WebView2 Grid.Row="1"
                                          x:Name="webview"
                                          Source="{Binding ServerLogUrl}"
                                          Cursor="Arrow"
                                          MouseWheel="Webview_MouseWheel"
                                          CoreWebView2InitializationCompleted="Webview_CoreWebView2InitializationCompleted"
                                          DefaultBackgroundColor="{DynamicResource WhiteBackground_Cl}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="16,10,16,16"
                            CornerRadius="8"
                            Padding="14,8"
                            Background="{DynamicResource ImmersiveGlassBackground}"
                            BorderBrush="{DynamicResource ImmersiveGlassBorder}"
                            BorderThickness="1">
                        <DockPanel LastChildFill="False">
                            <CheckBox DockPanel.Dock="Right"
                                      Content="Auto scroll to new entry"
                                      IsChecked="{Binding ScrollServerLogToBottom}"
                                      d:IsChecked="True"
                                      Cursor="Hand"
                                      Style="{StaticResource CircleCheckBox}"
                                      Foreground="{DynamicResource ImmersiveTextSecondary}"
                                      FontSize="13"
                                      VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
