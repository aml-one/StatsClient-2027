<Window x:Class="StatsClient.MVVM.View.OrderXmlCompareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XML Compare"
        Height="820"
        Width="1700"
        MinHeight="600"
        MinWidth="1200"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource TransparentBrush}">
    <Border CornerRadius="8,8,6,8"
            BorderThickness="0.5"
            BorderBrush="{DynamicResource BlackColor}"
            Background="{DynamicResource CodeEditorBackground}"
            ClipToBounds="True">
        <Border CornerRadius="8"
                Margin="10"
                BorderThickness="0.5"
                BorderBrush="{DynamicResource CodeEditorBorder}"
                Background="{DynamicResource CodeEditorBackground}"
                ClipToBounds="True">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0"
                           PreviewMouseDown="TitleBar_PreviewMouseDown"
                           Cursor="Hand"
                           Background="{DynamicResource TransparentBrush}"
                           Margin="0,0,0,8">
                    <Button x:Name="btnClose"
                            DockPanel.Dock="Right"
                            Width="24"
                            Height="24"
                            Padding="0"
                            Margin="0,0,0,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Cursor="Arrow"
                            Background="{DynamicResource TransparentBrush}"
                            BorderBrush="{DynamicResource TransparentBrush}"
                            Foreground="{DynamicResource CodeEditorForeground}"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Content="╳"
                            Click="CloseWindow_Click" />
                    <TextBlock Text="XML Compare"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource CodeEditorTitleForeground}"
                               FontSize="13"
                               FontWeight="SemiBold" />
                </DockPanel>

                <DockPanel Grid.Row="1"
                           Margin="0,0,0,8">
                    <CheckBox x:Name="checkSyncScroll"
                              DockPanel.Dock="Left"
                              Content="scoll in syncron"
                              IsChecked="True"
                              VerticalAlignment="Center"
                              Foreground="{DynamicResource CodeEditorForeground}"
                              Margin="0,0,12,0" />
                    <CheckBox x:Name="checkIgnoreTrailingSpaces"
                              DockPanel.Dock="Left"
                              Content="ignore trailing spaces"
                              IsChecked="True"
                              Checked="IgnoreTrailingSpaces_Changed"
                              Unchecked="IgnoreTrailingSpaces_Changed"
                              VerticalAlignment="Center"
                              Foreground="{DynamicResource CodeEditorForeground}"
                              Margin="0,0,12,0" />

                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="12,0,0,0">
                        <TextBlock x:Name="tbLoadState"
                                   Foreground="{DynamicResource CodeEditorStatusForeground}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Visibility="Collapsed" />
                        <ProgressBar x:Name="pbLoad"
                                     Width="180"
                                     Height="8"
                                     Minimum="0"
                                     Maximum="100"
                                     Visibility="Collapsed"
                                     Background="{DynamicResource CodeEditorHeaderBackground}"
                                     Foreground="{DynamicResource CodeEditorProgressForeground}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="tbStatus"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource CodeEditorStatusForeground}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,8,0" />
                        <TextBlock x:Name="tbChangeCount"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource CodeEditorCountForeground}"
                                   Margin="0,0,8,0" />
                        <Border Background="{DynamicResource CodeDiffRemovedBackground}"
                                CornerRadius="3"
                                Padding="8,2"
                                Margin="0,0,6,0">
                            <TextBlock x:Name="tbRemovedCount"
                                       Foreground="{DynamicResource CodeDiffRemovedForeground}"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Border Background="{DynamicResource CodeDiffAddedBackground}"
                                CornerRadius="3"
                                Padding="8,2">
                            <TextBlock x:Name="tbAddedCount"
                                       Foreground="{DynamicResource CodeDiffAddedForeground}"
                                       FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            BorderBrush="{DynamicResource CodeEditorBorder}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Background="{DynamicResource CodeEditorPanelBackground}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Background="{DynamicResource CodeEditorHeaderBackground}"
                                    BorderBrush="{DynamicResource CodeEditorBorder}"
                                    BorderThickness="0,0,0,1"
                                    Padding="8,5">
                                <TextBlock x:Name="tbXmlTitle"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource CodeEditorTitleForeground}"
                                           TextTrimming="CharacterEllipsis" />
                            </Border>

                            <RichTextBox x:Name="editorXml"
                                         Grid.Row="1"
                                         Margin="0"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         IsDocumentEnabled="False"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         Foreground="{DynamicResource CodeEditorForeground}"
                                         PreviewMouseWheel="Editor_PreviewMouseWheel"
                                         Background="{DynamicResource CodeEditorBackground}" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            BorderBrush="{DynamicResource CodeEditorBorder}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Background="{DynamicResource CodeEditorPanelBackground}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Background="{DynamicResource CodeEditorHeaderBackground}"
                                    BorderBrush="{DynamicResource CodeEditorBorder}"
                                    BorderThickness="0,0,0,1"
                                    Padding="8,5">
                                <TextBlock x:Name="tbStCopyTitle"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource CodeEditorTitleForeground}"
                                           TextTrimming="CharacterEllipsis" />
                            </Border>

                            <RichTextBox x:Name="editorStCopy"
                                         Grid.Row="1"
                                         Margin="0"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         IsDocumentEnabled="False"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         Foreground="{DynamicResource CodeEditorForeground}"
                                         PreviewMouseWheel="Editor_PreviewMouseWheel"
                                         Background="{DynamicResource CodeEditorBackground}" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
