                        <Image x:Name="logoGlow"
                               Source="/Images/stats_2025_Q512.png"
                               Width="216"
                               Height="216"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="0"
                               Panel.ZIndex="10">
                            <Image.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform />
                                    <RotateTransform />
                                    <TranslateTransform />
                                </TransformGroup>
                            </Image.RenderTransform>
                            <Image.Effect>
                                <BlurEffect Radius="18" />
                            </Image.Effect>
                        </Image>
                        <Image x:Name="logo"
                               Source="/Images/stats_2025_Q512.png"
                               Width="200"
                               Height="200"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="0"
                               Panel.ZIndex="11">
                            <Image.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform />
                                    <RotateTransform />
                                    <TranslateTransform />
                                </TransformGroup>
                            </Image.RenderTransform>
