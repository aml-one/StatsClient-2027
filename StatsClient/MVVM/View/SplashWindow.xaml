                                    Grid.Column="1"
                                    VerticalAlignment="Bottom"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,12,80">
                            <TextBlock x:Name="versionGlow"
                                       Text="{Binding SoftwareVersion, StringFormat='v\{0}'}"
                                       FontSize="110"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SplashWarningTextSoft}"
                                       HorizontalAlignment="Center"
                                       Opacity="0"
                                       Margin="0,0,0,0">
                                <TextBlock.Effect>
                                    <BlurEffect Radius="7" />
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock x:Name="versionNumber"
                                       Text="{Binding SoftwareVersion, StringFormat='v\{0}'}"
                                       FontSize="1"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SplashWarningTextFaint}"
                                       HorizontalAlignment="Center"
                                       Opacity="0"
                                       Cursor="Hand">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform />
                                </TextBlock.RenderTransform>
        <i:Interaction.Triggers>
            <i:EventTrigger EventName="MouseDown">
                <i:InvokeCommandAction Command="{Binding ResetWindowPositionCommand}" />
            </i:EventTrigger>
        </i:Interaction.Triggers>
                            </TextBlock>
                        </StackPanel>

