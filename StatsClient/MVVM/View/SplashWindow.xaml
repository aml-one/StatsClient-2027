                                Background="{DynamicResource SplashCardBackground}"
                                CornerRadius="10"
                                Opacity="0"
                                Panel.ZIndex="20"
                                RenderTransformOrigin="0.5,1">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform />
                                    <TranslateTransform />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Border CornerRadius="10"
                                    BorderThickness="1"
                                    Margin="1">
                                <Border.BorderBrush>
                                    <LinearGradientBrush x:Name="shimmerTransform"
                                                         StartPoint="0,0"
                                                         EndPoint="1,0">
                                        <LinearGradientBrush.Transform>
                                            <TranslateTransform X="-1" />
                                        </LinearGradientBrush.Transform>
                                        <GradientStop Color="{DynamicResource SplashCardShimmerStart_Cl}"
                                                      Offset="0" />
                                        <GradientStop Color="{DynamicResource SplashCardShimmerMid_Cl}"
                                                      Offset="0.5" />
                                        <GradientStop Color="{DynamicResource SplashCardShimmerStart_Cl}"
                                                      Offset="1" />
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Grid Margin="16,10,16,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="4" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal"
                                                Grid.Row="0"
                                                Grid.Column="0"
                                                VerticalAlignment="Center">
                                        <TextBlock x:Name="statsText"
                                                   Text="Stats "
                                                   FontSize="34"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SplashBodyForeground}"
                                                   Opacity="0">
                                            <TextBlock.RenderTransform>
                                                <TranslateTransform />
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                        <TextBlock x:Name="yearText"
                                                   Text="2027"
                                                   FontSize="34"
                                                   FontWeight="Thin"
                                                   Foreground="{DynamicResource SplashWarningOrange}"
                                                   Margin="-4,0,0,0"
                                                   Opacity="0">
                                            <TextBlock.RenderTransform>
                                                <TranslateTransform />
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                    </StackPanel>

                                    <TextBlock x:Name="loadingText"
                                               Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               Text="{Binding LoadingText}"
                                               d:Text="Checking server connection.."
                                               FontSize="9.5"
                                               Foreground="{DynamicResource SplashCardSubtitle}"
                                               Margin="0,5,0,0" />
                                    <Grid Grid.Row="2"
                                          Grid.ColumnSpan="2"
                                          Margin="0,4,0,0"
                                          Height="3">
                                        <Border Background="{DynamicResource SplashCardBorder}"
                                                CornerRadius="1.5" />
                                        <Rectangle x:Name="progressBar"
                                                   Width="{Binding LoadingProgress}"
                                                   HorizontalAlignment="Left"
                                                   RadiusX="1.5"
                                                   RadiusY="1.5">
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0"
                                                                     EndPoint="1,0">
                                                    <GradientStop Color="{DynamicResource SplashWarningGradientStart_Cl}"
                                                                  Offset="0" />
                                                    <GradientStop Color="{DynamicResource SplashWarningGradientEnd_Cl}"
                                                                  Offset="1" />
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                            <Rectangle.Effect>
                                                <DropShadowEffect Color="{DynamicResource SplashWarningOrange_Cl}"
                                                                  Direction="0"
                                                                  ShadowDepth="0"
                                                                  BlurRadius="5"
                                                                  Opacity="0.45" />
                                            </Rectangle.Effect>
                                        </Rectangle>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Border>

                        <TextBlock Text="Window position got reset to default position"
                                   FontSize="8"
