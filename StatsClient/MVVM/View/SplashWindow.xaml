<Window x:Class="StatsClient.MVVM.View.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodel="clr-namespace:StatsClient.MVVM.ViewModel"
        xmlns:converter="clr-namespace:StatsClient.MVVM.Converters"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Loaded="Window_Loaded"
        Title="Stats 2027"
        Height="300"
        Width="500"
        Background="{DynamicResource TransparentBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <converter:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />

            <QuarticEase x:Key="QuarticEaseOut"
                         EasingMode="EaseOut" />
            <QuarticEase x:Key="QuarticEaseInOut"
                         EasingMode="EaseInOut" />
            <BackEase x:Key="BackEaseOut"
                      EasingMode="EaseOut"
                      Amplitude="0.3" />
            <SineEase x:Key="SineEaseInOut"
                      EasingMode="EaseInOut" />
            <QuadraticEase x:Key="QuadraticEaseInOut"
                           EasingMode="EaseInOut" />

            <Storyboard x:Key="IntroAmlAnimation">
                <DoubleAnimation Storyboard.TargetName="introAmlGlow"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0"
                                 To="0.55"
                                 Duration="0:0:1.0"
                                 EasingFunction="{StaticResource QuarticEaseOut}" />
                <DoubleAnimation Storyboard.TargetName="introAmlText"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0"
                                 To="1"
                                 Duration="0:0:1.0"
                                 EasingFunction="{StaticResource QuarticEaseOut}" />
                <DoubleAnimation Storyboard.TargetName="introAmlText"
                                 Storyboard.TargetProperty="(RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                 From="0.8"
                                 To="1"
                                 Duration="0:0:1.0"
                                 EasingFunction="{StaticResource BackEaseOut}" />
                <DoubleAnimation Storyboard.TargetName="introAmlText"
                                 Storyboard.TargetProperty="(RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                 From="0.8"
                                 To="1"
                                 Duration="0:0:1.0"
                                 EasingFunction="{StaticResource BackEaseOut}" />
            </Storyboard>
            <Storyboard x:Key="IntroAmlFadeOutAnimation">
                <DoubleAnimation Storyboard.TargetName="introAmlGlow"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0.55"
                                 To="0"
                                 Duration="0:0:0.6"
                                 EasingFunction="{StaticResource QuarticEaseInOut}" />
                <DoubleAnimation Storyboard.TargetName="introAmlText"
                                 Storyboard.TargetProperty="Opacity"
                                 From="1"
                                 To="0"
                                 Duration="0:0:0.6"
                                 EasingFunction="{StaticResource QuarticEaseInOut}" />
            </Storyboard>
            <Storyboard x:Key="IntroPresentsAnimation">
                <DoubleAnimation Storyboard.TargetName="introPresentsText"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0"
                                 To="1"
                                 Duration="0:0:0.7"
                                 EasingFunction="{StaticResource QuarticEaseOut}" />
                <DoubleAnimation Storyboard.TargetName="introPresentsText"
                                 Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                                 From="14"
                                 To="0"
                                 Duration="0:0:0.7"
                                 EasingFunction="{StaticResource QuarticEaseOut}" />
            </Storyboard>
            <Storyboard x:Key="IntroPresensFadeOutAnimation">
                <DoubleAnimation Storyboard.TargetName="introPresentsText"
                                 Storyboard.TargetProperty="Opacity"
                                 From="1"
                                 To="0"
                                 Duration="0:0:0.5"
                                 EasingFunction="{StaticResource QuarticEaseInOut}" />
            </Storyboard>

            <Storyboard x:Key="LogoOpacityAnimation">
                <DoubleAnimation Storyboard.TargetName="logo"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0"
                                 To="1"
                                 Duration="0:0:0.8"
                                 EasingFunction="{StaticResource QuarticEaseOut}" />
                <DoubleAnimation Storyboard.TargetName="logo"
                                 Storyboard.TargetProperty="(RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                 From="0.5"
                                 To="1"
                                 Duration="0:0:0.8"
                                 EasingFunction="{StaticResource BackEaseOut}" />
                <DoubleAnimation Storyboard.TargetName="logo"
                                 Storyboard.TargetProperty="(RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                 From="0.5"
                                 To="1"
                                 Duration="0:0:0.8"
                                 EasingFunction="{StaticResource BackEaseOut}" />
                <DoubleAnimation Storyboard.TargetName="logo"
                                 Storyboard.TargetProperty="(RenderTransform).(TransformGroup.Children)[1].(RotateTransform.Angle)"
                                 From="-360"
                                 To="0"
                                 Duration="0:0:0.8"
                                 EasingFunction="{StaticResource QuarticEaseOut}" />
                <DoubleAnimation Storyboard.TargetName="logoGlow"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0"
                                 To="0.5"
                                 Duration="0:0:0.7"
                                 AutoReverse="True"
                                 RepeatBehavior="2x" />
            </Storyboard>

            <Storyboard x:Key="LogoMoveAnimation">
                <DoubleAnimation Storyboard.TargetName="logo"
                                 Storyboard.TargetProperty="(RenderTransform).(TransformGroup.Children)[2].(TranslateTransform.X)"
                                 To="0"
                                 Duration="0:0:0.9"
                                 EasingFunction="{StaticResource QuarticEaseInOut}" />
                <DoubleAnimation Storyboard.TargetName="logo"
                                 Storyboard.TargetProperty="(RenderTransform).(TransformGroup.Children)[2].(TranslateTransform.Y)"
                                 To="-72"
                                 Duration="0:0:0.9"
                                 EasingFunction="{StaticResource QuarticEaseInOut}" />
                <DoubleAnimation Storyboard.TargetName="logoGlow"
                                 Storyboard.TargetProperty="(RenderTransform).(TransformGroup.Children)[2].(TranslateTransform.X)"
                                 To="0"
                                 Duration="0:0:0.9"
                                 EasingFunction="{StaticResource QuarticEaseInOut}" />
                <DoubleAnimation Storyboard.TargetName="logoGlow"
                                 Storyboard.TargetProperty="(RenderTransform).(TransformGroup.Children)[2].(TranslateTransform.Y)"
                                 To="-72"
                                 Duration="0:0:0.9"
                                 EasingFunction="{StaticResource QuarticEaseInOut}" />
            </Storyboard>
            <Storyboard x:Key="LogoSizeAnimation">
                <DoubleAnimation Storyboard.TargetName="logo"
                                 Storyboard.TargetProperty="Width"
                                 From="200"
                                 To="76"
                                 Duration="0:0:0.9"
                                 EasingFunction="{StaticResource BackEaseOut}" />
                <DoubleAnimation Storyboard.TargetName="logoGlow"
                                 Storyboard.TargetProperty="Width"
                                 From="216"
                                 To="88"
                                 Duration="0:0:0.9"
                                 EasingFunction="{StaticResource BackEaseOut}" />
            </Storyboard>
            <Storyboard x:Key="PanelOpacityAnimation">
                <DoubleAnimation Storyboard.TargetName="panel"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0"
                                 To="1"
                                 Duration="0:0:0.6"
                                 EasingFunction="{StaticResource QuarticEaseOut}" />
                <DoubleAnimation Storyboard.TargetName="panel"
                                 Storyboard.TargetProperty="(RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                 From="0.96"
                                 To="1"
                                 Duration="0:0:0.6"
                                 EasingFunction="{StaticResource BackEaseOut}" />
                <DoubleAnimation Storyboard.TargetName="panel"
                                 Storyboard.TargetProperty="(RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                 From="0.96"
                                 To="1"
                                 Duration="0:0:0.6"
                                 EasingFunction="{StaticResource BackEaseOut}" />
                <ThicknessAnimation Storyboard.TargetName="panel"
                                    Storyboard.TargetProperty="Margin"
                                    From="16,0,16,-100"
                                    To="16,0,16,16"
                                    Duration="0:0:0.6"
                                    EasingFunction="{StaticResource QuarticEaseOut}" />
            </Storyboard>
            <Storyboard x:Key="Panel2OpacityAnimation">
                <DoubleAnimation Storyboard.TargetName="panel2"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0"
                                 To="0.7"
                                 Duration="0:0:0.55"
                                 EasingFunction="{StaticResource QuarticEaseOut}" />
            </Storyboard>
            <Storyboard x:Key="BackgroundEaseInAnimation">
                <DoubleAnimation Storyboard.TargetName="background"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0"
                                 To="0.6"
                                 Duration="0:0:1.0"
                                 EasingFunction="{StaticResource QuarticEaseInOut}" />
            </Storyboard>
            <Storyboard x:Key="BackgroundEaseOutAnimation">
                <DoubleAnimation Storyboard.TargetName="background"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0.6"
                                 To="0"
                                 Duration="0:0:0.8"
                                 EasingFunction="{StaticResource QuarticEaseInOut}" />
            </Storyboard>
            <Storyboard x:Key="BackgroundZoomAndMoveAnimation">
                <DoubleAnimation Storyboard.TargetName="backgroundOverlay"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0.3"
                                 To="0.12"
                                 Duration="0:0:2.5"
                                 EasingFunction="{StaticResource QuarticEaseOut}" />
            </Storyboard>
            <Storyboard x:Key="BackgroundPulseOutAnimation">
                <DoubleAnimation Storyboard.TargetName="background"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0.6"
                                 To="0.3"
                                 Duration="0:0:1.2"
                                 EasingFunction="{StaticResource SineEaseInOut}" />
            </Storyboard>
            <Storyboard x:Key="BackgroundPulseInAnimation">
                <DoubleAnimation Storyboard.TargetName="background"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0.3"
                                 To="0.6"
                                 Duration="0:0:1.2"
                                 EasingFunction="{StaticResource SineEaseInOut}" />
            </Storyboard>
            <Storyboard x:Key="StatsTextAnimation">
                <DoubleAnimation Storyboard.TargetName="statsText"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0"
                                 To="1"
                                 Duration="0:0:0.45"
                                 BeginTime="0:0:0.1"
                                 EasingFunction="{StaticResource QuarticEaseOut}" />
                <DoubleAnimation Storyboard.TargetName="statsText"
                                 Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                                 From="-14"
                                 To="0"
                                 Duration="0:0:0.45"
                                 BeginTime="0:0:0.1"
                                 EasingFunction="{StaticResource QuarticEaseOut}" />
                <DoubleAnimation Storyboard.TargetName="yearText"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0"
                                 To="1"
                                 Duration="0:0:0.45"
                                 BeginTime="0:0:0.3"
                                 EasingFunction="{StaticResource QuarticEaseOut}" />
                <DoubleAnimation Storyboard.TargetName="yearText"
                                 Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                                 From="14"
                                 To="0"
                                 Duration="0:0:0.45"
                                 BeginTime="0:0:0.3"
                                 EasingFunction="{StaticResource QuarticEaseOut}" />
            </Storyboard>
            <Storyboard x:Key="VersionNumberEaseInAnimation">
                <DoubleAnimation Storyboard.TargetName="versionNumber"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0"
                                 To="1"
                                 Duration="0:0:0.7"
                                 EasingFunction="{StaticResource QuarticEaseOut}" />
                <DoubleAnimation Storyboard.TargetName="versionNumber"
                                 Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                                 From="10"
                                 To="0"
                                 Duration="0:0:0.7"
                                 EasingFunction="{StaticResource QuarticEaseOut}" />
                <DoubleAnimation Storyboard.TargetName="versionGlow"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0"
                                 To="0.85"
                                 Duration="0:0:1.5"
                                 BeginTime="0:0:0.4"
                                 AutoReverse="True"
                                 RepeatBehavior="Forever"
                                 EasingFunction="{StaticResource SineEaseInOut}" />
            </Storyboard>
            <Storyboard x:Key="GradientOverlayAnimation"
                        RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="gradientStop1"
                                 Storyboard.TargetProperty="Offset"
                                 From="0"
                                 To="0.85"
                                 Duration="0:0:4"
                                 AutoReverse="True"
                                 EasingFunction="{StaticResource SineEaseInOut}" />
                <DoubleAnimation Storyboard.TargetName="gradientStop2"
                                 Storyboard.TargetProperty="Offset"
                                 From="0.35"
                                 To="1.1"
                                 Duration="0:0:4"
                                 AutoReverse="True"
                                 EasingFunction="{StaticResource SineEaseInOut}" />
            </Storyboard>
            <Storyboard x:Key="LoadingTextAnimation"
                        RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="loadingText"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0.5"
                                 To="1"
                                 Duration="0:0:1.1"
                                 AutoReverse="True"
                                 EasingFunction="{StaticResource SineEaseInOut}" />
            </Storyboard>
            <Storyboard x:Key="ParticleAnimation1"
                        RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="particle1"
                                 Storyboard.TargetProperty="(Canvas.Top)"
                                 From="310"
                                 To="-30"
                                 Duration="0:0:7" />
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="particle1"
                                               Storyboard.TargetProperty="Opacity">
                    <LinearDoubleKeyFrame KeyTime="0:0:0"
                                          Value="0" />
                    <LinearDoubleKeyFrame KeyTime="0:0:0.8"
                                          Value="0.55" />
                    <LinearDoubleKeyFrame KeyTime="0:0:6"
                                          Value="0.55" />
                    <LinearDoubleKeyFrame KeyTime="0:0:7"
                                          Value="0" />
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>
            <Storyboard x:Key="ParticleAnimation2"
                        RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="particle2"
                                 Storyboard.TargetProperty="(Canvas.Top)"
                                 From="310"
                                 To="-20"
                                 Duration="0:0:9.5" />
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="particle2"
                                               Storyboard.TargetProperty="Opacity">
                    <LinearDoubleKeyFrame KeyTime="0:0:0"
                                          Value="0" />
                    <LinearDoubleKeyFrame KeyTime="0:0:1.2"
                                          Value="0.4" />
                    <LinearDoubleKeyFrame KeyTime="0:0:8.2"
                                          Value="0.4" />
                    <LinearDoubleKeyFrame KeyTime="0:0:9.5"
                                          Value="0" />
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>
            <Storyboard x:Key="ParticleAnimation3"
                        RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="particle3"
                                 Storyboard.TargetProperty="(Canvas.Top)"
                                 From="310"
                                 To="-40"
                                 Duration="0:0:11.5" />
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="particle3"
                                               Storyboard.TargetProperty="Opacity">
                    <LinearDoubleKeyFrame KeyTime="0:0:0"
                                          Value="0" />
                    <LinearDoubleKeyFrame KeyTime="0:0:1.1"
                                          Value="0.5" />
                    <LinearDoubleKeyFrame KeyTime="0:0:10.2"
                                          Value="0.5" />
                    <LinearDoubleKeyFrame KeyTime="0:0:11.5"
                                          Value="0" />
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>
            <Storyboard x:Key="ShimmerAnimation"
                        RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="shimmerTransform"
                                 Storyboard.TargetProperty="Transform.(TranslateTransform.X)"
                                 From="-1.5"
                                 To="2.5"
                                 Duration="0:0:2.3"
                                 EasingFunction="{StaticResource QuadraticEaseInOut}" />
            </Storyboard>
            <Storyboard x:Key="ProgressBarAnimation">
                <DoubleAnimation Storyboard.TargetName="progressBar"
                                 Storyboard.TargetProperty="Width"
                                 From="0"
                                 To="436"
                                 Duration="0:0:4.5"
                                 EasingFunction="{StaticResource QuarticEaseInOut}" />
            </Storyboard>

            <ResourceDictionary.MergedDictionaries>            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Window.DataContext>
        <viewmodel:SplashViewModel />
    </Window.DataContext>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource GradientOverlayAnimation}" />
            <BeginStoryboard Storyboard="{StaticResource ParticleAnimation1}" />
            <BeginStoryboard Storyboard="{StaticResource ParticleAnimation2}" />
            <BeginStoryboard Storyboard="{StaticResource ParticleAnimation3}" />
            <BeginStoryboard Storyboard="{StaticResource LoadingTextAnimation}" />
            <BeginStoryboard Storyboard="{StaticResource BackgroundZoomAndMoveAnimation}" />
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <!-- Outer blue glow -->
        <Border CornerRadius="16"
                Margin="6"
                Background="{DynamicResource TransparentBrush}">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource SplashAccentBlue_Cl}"
                                  Direction="270"
                                  ShadowDepth="0"
                                  BlurRadius="24"
                                  Opacity="0.18" />
            </Border.Effect>
        </Border>

        <!-- Dark elevation shadow -->
        <Border CornerRadius="16"
                Margin="4"
                Background="{DynamicResource TransparentBrush}">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource LightGrayBorderAndShadowColor_Cl}"
                                  Direction="270"
                                  ShadowDepth="5"
                                  BlurRadius="30"
                                  Opacity="0.28" />
            </Border.Effect>
        </Border>

        <!-- Gradient ring: 1.5px gold-to-dim border -->
        <Border CornerRadius="15"
                Margin="5"
                Padding="1.5">
            <Border.Background>
                <LinearGradientBrush StartPoint="0.15,0"
                                     EndPoint="0.85,1">
                    <GradientStop Color="{DynamicResource SplashRingGradientStart_Cl}"
                                  Offset="0" />
                    <GradientStop Color="{DynamicResource SplashRingGradientMid_Cl}"
                                  Offset="0.5" />
                    <GradientStop Color="{DynamicResource SplashRingGradientEnd_Cl}"
                                  Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <!-- Main card -->
            <Border CornerRadius="14"
                    Background="{DynamicResource SplashBackground}"
                    ClipToBounds="True">
                <Grid>
                    <!-- Inner top highlight -->
                    <Rectangle Height="1"
                               VerticalAlignment="Top"
                               IsHitTestVisible="False"
                               Panel.ZIndex="200">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,0">
                                <GradientStop Color="{DynamicResource TransparentColor_Cl}"
                                              Offset="0" />
                                <GradientStop Color="{DynamicResource SplashHighlightSoft_Cl}"
                                              Offset="0.25" />
                                <GradientStop Color="{DynamicResource SplashHighlightFaint_Cl}"
                                              Offset="0.75" />
                                <GradientStop Color="{DynamicResource TransparentColor_Cl}"
                                              Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <!-- Inner bottom blue whisper -->
                    <Rectangle Height="1"
                               VerticalAlignment="Bottom"
                               IsHitTestVisible="False"
                               Panel.ZIndex="200">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,0">
                                <GradientStop Color="{DynamicResource TransparentColor_Cl}"
                                              Offset="0" />
                                <GradientStop Color="{DynamicResource SplashRingGradientMid_Cl}"
                                              Offset="0.5" />
                                <GradientStop Color="{DynamicResource TransparentColor_Cl}"
                                              Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <Grid>

                        <!-- Radial warm glow -->
                        <Rectangle x:Name="background"
                                   Opacity="0"
                                   IsHitTestVisible="False">
                            <Rectangle.Fill>
                                <RadialGradientBrush GradientOrigin="0.5,0.3"
                                                     Center="0.5,0.3"
                                                     RadiusX="0.55"
                                                     RadiusY="0.55">
                                    <GradientStop Color="{DynamicResource SplashGlowAccent_Cl}"
                                                  Offset="0" />
                                    <GradientStop Color="{DynamicResource TransparentColor_Cl}"
                                                  Offset="1" />
                                </RadialGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Animated gradient wash -->
                        <Rectangle x:Name="backgroundOverlay"
                                   Opacity="0.22"
                                   IsHitTestVisible="False">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,1">
                                    <GradientStop x:Name="gradientStop1"
                                                  Color="{DynamicResource SplashWashStart_Cl}"
                                                  Offset="0" />
                                    <GradientStop x:Name="gradientStop2"
                                                  Color="{DynamicResource SplashWashMid_Cl}"
                                                  Offset="0.5" />
                                    <GradientStop Color="{DynamicResource SplashWashEnd_Cl}"
                                                  Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Gold top-edge accent bar -->
                        <Rectangle Height="2"
                                   VerticalAlignment="Top"
                                   IsHitTestVisible="False">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,0">
                                    <GradientStop Color="{DynamicResource TransparentColor_Cl}"
                                                  Offset="0" />
                                    <GradientStop Color="{DynamicResource SplashAccentBar_Cl}"
                                                  Offset="0.5" />
                                    <GradientStop Color="{DynamicResource TransparentColor_Cl}"
                                                  Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Soft ambient center glow -->
                        <Ellipse Width="330"
                                 Height="170"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Margin="0,-28,0,0"
                                 Opacity="0.16"
                                 IsHitTestVisible="False">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="{DynamicResource SplashGlowStrong_Cl}"
                                                  Offset="0" />
                                    <GradientStop Color="{DynamicResource TransparentColor_Cl}"
                                                  Offset="1" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <BlurEffect Radius="24" />
                            </Ellipse.Effect>
                        </Ellipse>

                        <!-- Bottom horizon glow line above info panel -->
                        <Rectangle Height="1"
                                   VerticalAlignment="Bottom"
                                   Margin="34,0,34,126"
                                   IsHitTestVisible="False"
                                   Opacity="0.75">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,0">
                                    <GradientStop Color="{DynamicResource TransparentColor_Cl}"
                                                  Offset="0" />
                                    <GradientStop Color="{DynamicResource SplashGlowMedium_Cl}"
                                                  Offset="0.5" />
                                    <GradientStop Color="{DynamicResource TransparentColor_Cl}"
                                                  Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Subtle left-side dot cluster to balance right side -->
                        <Canvas IsHitTestVisible="False"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="38,54,0,0"
                                Opacity="0.45">
                            <Ellipse Width="2.3"
                                     Height="2.3"
                                     Fill="{DynamicResource SplashParticleStrong}"
                                     Canvas.Left="0"
                                     Canvas.Top="0" />
                            <Ellipse Width="2.3"
                                     Height="2.3"
                                     Fill="{DynamicResource SplashParticleStrong}"
                                     Canvas.Left="14"
                                     Canvas.Top="0" />
                            <Ellipse Width="2.3"
                                     Height="2.3"
                                     Fill="{DynamicResource SplashParticleMid}"
                                     Canvas.Left="28"
                                     Canvas.Top="0" />
                            <Ellipse Width="2.3"
                                     Height="2.3"
                                     Fill="{DynamicResource SplashParticleMid}"
                                     Canvas.Left="0"
                                     Canvas.Top="14" />
                            <Ellipse Width="2.3"
                                     Height="2.3"
                                     Fill="{DynamicResource SplashParticleMid}"
                                     Canvas.Left="14"
                                     Canvas.Top="14" />
                            <Ellipse Width="2.3"
                                     Height="2.3"
                                     Fill="{DynamicResource SplashParticleFaint}"
                                     Canvas.Left="28"
                                     Canvas.Top="14" />
                        </Canvas>

                        <!-- Corner brackets + dot grid -->
                        <Grid IsHitTestVisible="False">
                            <Canvas Width="12"
                                    Height="12"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="18,18,0,0">
                                <Line X1="0"
                                      Y1="12"
                                      X2="0"
                                      Y2="0"
                                      Stroke="{DynamicResource SplashOrbitStroke}"
                                      StrokeThickness="1.5"
                                      SnapsToDevicePixels="True" />
                                <Line X1="0"
                                      Y1="0"
                                      X2="12"
                                      Y2="0"
                                      Stroke="{DynamicResource SplashOrbitStroke}"
                                      StrokeThickness="1.5"
                                      SnapsToDevicePixels="True" />
                            </Canvas>

                            <Canvas Width="12"
                                    Height="12"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,18,18,0">
                                <Line X1="0"
                                      Y1="0"
                                      X2="12"
                                      Y2="0"
                                      Stroke="{DynamicResource SplashOrbitStroke}"
