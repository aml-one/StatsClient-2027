                                   FontSize="10"
                                   IsHitTestVisible="False" />
                    </Border>
                </Grid>
            </Border>



            <!-- Sculpt tool panel (top-right; replaces Order Info "Last touched by" while active) -->
            <Border x:Name="SculptToolPanel"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,8,10,0"
                    Width="190"
                    Padding="10,8"
                    Background="#A8E5E9ED"
                    BorderBrush="#55A8B0B8"
                    BorderThickness="1"
                    CornerRadius="4"
                    Panel.ZIndex="26"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Sculpt brush"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#FF1D2A38"
                               Margin="0,0,0,6" />
                    <UniformGrid Columns="4"
                                 Margin="0,0,0,8">
                        <Button Command="{Binding SelectSculptToolCommand}"
                                CommandParameter="Add"
                                ToolTip="Add material"
                                Margin="0,0,4,0">
                            <Button.Style>
                                <Style TargetType="Button"
                                       BasedOn="{StaticResource SculptToolSelectButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SculptToolName}"
                                                     Value="Add">
                                            <Setter Property="Background"
                                                    Value="#FFC5D8EE" />
                                            <Setter Property="BorderBrush"
                                                    Value="#FF2A6AA3" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Image Source="/DcmViewer/Images/add.png"
                                   Width="22"
                                   Height="22"
                                   Stretch="Uniform" />
                        </Button>
                        <Button Command="{Binding SelectSculptToolCommand}"
                                CommandParameter="Remove"
                                ToolTip="Remove material"
                                Margin="0,0,4,0">
                            <Button.Style>
                                <Style TargetType="Button"
                                       BasedOn="{StaticResource SculptToolSelectButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SculptToolName}"
                                                     Value="Remove">
                                            <Setter Property="Background"
                                                    Value="#FFC5D8EE" />
                                            <Setter Property="BorderBrush"
                                                    Value="#FF2A6AA3" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Image Source="/DcmViewer/Images/remove.png"
                                   Width="22"
                                   Height="22"
                                   Stretch="Uniform" />
                        </Button>
                        <Button Command="{Binding SelectSculptToolCommand}"
                                CommandParameter="Smooth"
                                ToolTip="Smooth surface"
                                Margin="0,0,4,0">
                            <Button.Style>
                                <Style TargetType="Button"
                                       BasedOn="{StaticResource SculptToolSelectButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SculptToolName}"
                                                     Value="Smooth">
                                            <Setter Property="Background"
                                                    Value="#FFC5D8EE" />
                                            <Setter Property="BorderBrush"
                                                    Value="#FF2A6AA3" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Image Source="/DcmViewer/Images/smooth.png"
                                   Width="22"
                                   Height="22"
                                   Stretch="Uniform" />
                        </Button>
                        <Button Command="{Binding SelectSculptToolCommand}"
                                CommandParameter="Grab"
                                ToolTip="Grab / move"
                                Margin="0">
                            <Button.Style>
                                <Style TargetType="Button"
                                       BasedOn="{StaticResource SculptToolSelectButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SculptToolName}"
                                                     Value="Grab">
                                            <Setter Property="Background"
                                                    Value="#FFC5D8EE" />
                                            <Setter Property="BorderBrush"
                                                    Value="#FF2A6AA3" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Image Source="/DcmViewer/Images/grab_move.png"
                                   Width="22"
                                   Height="22"
                                   Stretch="Uniform" />
                        </Button>
                    </UniformGrid>
                    <Slider Style="{StaticResource SculptKnobSlider}"
                            Tag="/DcmViewer/Images/radius_icon.png"
                            Minimum="0.20"
                            Maximum="3"
                            Value="{Binding SculptBrushRadiusMm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            TickFrequency="0.05"
                            IsSnapToTickEnabled="False"
                            Margin="0,0,0,2" />
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="10"
                               Foreground="#FF4A5C6C"
                               Margin="0,0,0,8"
                               Text="{Binding SculptBrushRadiusMm, StringFormat={}{0:0.00} mm}" />
                    <Slider Style="{StaticResource SculptKnobSlider}"
                            Tag="/DcmViewer/Images/amplitude_icon.png"
                            Minimum="0.05"
                            Maximum="1"
                            Value="{Binding SculptBrushStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            TickFrequency="0.05"
                            IsSnapToTickEnabled="False"
                            Margin="0,0,0,2" />
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="10"
                               Foreground="#FF4A5C6C"
                               Margin="0,0,0,10"
                               Text="{Binding SculptBrushStrength, StringFormat={}{0:0.00}}" />
                    <UniformGrid Columns="4"
                                 Margin="0,0,0,0">
                        <Button Style="{StaticResource SculptPanelIconButton}"
                                Command="{Binding UndoSculptCommand}"
                                IsEnabled="{Binding CanUndoSculpt}"
                                ToolTip="Undo last stroke (Ctrl+Z)"
                                Margin="0,0,4,0">
                            <Image Source="/DcmViewer/Images/undo.png"
                                   Width="22"
                                   Height="22"
                                   Stretch="Uniform" />
                        </Button>
                        <Button Style="{StaticResource SculptPanelIconButton}"
                                Command="{Binding UndoAllSculptCommand}"
                                IsEnabled="{Binding CanUndoAllSculpt}"
                                ToolTip="Undo all sculpt changes"
                                Margin="0,0,4,0">
                            <Image Source="/DcmViewer/Images/undo_all.png"
                                   Width="22"
                                   Height="22"
                                   Stretch="Uniform" />
                        </Button>
                        <Button Style="{StaticResource SculptPanelIconButton}"
                                Command="{Binding RedoSculptCommand}"
                                IsEnabled="{Binding CanRedoSculpt}"
                                ToolTip="Redo (Ctrl+Y)"
                                Margin="0,0,4,0">
                            <Image Source="/DcmViewer/Images/redo.png"
                                   Width="22"
                                   Height="22"
                                   Stretch="Uniform" />
                        </Button>
                        <Button Style="{StaticResource SculptPanelIconButton}"
                                Command="{Binding SaveSculptedDcmCommand}"
                                IsEnabled="{Binding CanSaveSculptedDcm}"
                                ToolTip="Save sculpted geometry to DCM (.dcm.bak backup)"
                                Margin="0">
                            <Image Source="/DcmViewer/Images/save.png"
                                   Width="22"
                                   Height="22"
                                   Stretch="Uniform" />
                        </Button>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Status text bottom-left (hidden while center loading overlay is shown) -->
            <Border x:Name="BottomStatusBorder"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="50,0,0,8"
                    Padding="0,6"
                    Background="#00F4F7FB"
                    BorderBrush="#99B8C6D5"
                    BorderThickness="0"
                    CornerRadius="4"
                    IsHitTestVisible="False"
                    Panel.ZIndex="5">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}"
                                         Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock x:Name="BottomStatusText"
                           Text="{Binding StatusText}"
                           FontSize="11"
                           Foreground="#FF23313E"
                           TextWrapping="Wrap"
                           MaxWidth="360" />
            </Border>

            <Border x:Name="EncodeMeasureThumbnailsPanel"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,10,92"
                    Padding="0"
                    Panel.ZIndex="26"
                    Visibility="Collapsed"
                    Background="Transparent"
                    BorderThickness="0"
                    IsHitTestVisible="False">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom">
                    <Border Width="120"
                            Margin="0,0,6,0"
                            Padding="2"
                            Background="#F0F8FCFD"
                            BorderBrush="#FFB8C6D5"
                            BorderThickness="1"
                            CornerRadius="2">
                        <StackPanel>
                            <Image x:Name="EncodeCutImage0"
                                   Height="88"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                            <TextBlock x:Name="EncodeCutLabel0"
                                       Margin="0,3,0,2"
                                       HorizontalAlignment="Center"
                                       FontSize="10"
                                       Foreground="#FF23313E" />
                        </StackPanel>
                    </Border>
                    <Border Width="120"
                            Margin="0,0,6,0"
                            Padding="2"
                            Background="#F0F8FCFD"
                            BorderBrush="#FFB8C6D5"
                            BorderThickness="1"
                            CornerRadius="2">
                        <StackPanel>
                            <Image x:Name="EncodeCutImage1"
                                   Height="88"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                            <TextBlock x:Name="EncodeCutLabel1"
                                       Margin="0,3,0,2"
                                       HorizontalAlignment="Center"
                                       FontSize="10"
                                       Foreground="#FF23313E" />
                        </StackPanel>
                    </Border>
                    <Border Width="120"
                            Padding="2"
                            Background="#F0F8FCFD"
                            BorderBrush="#FFB8C6D5"
                            BorderThickness="1"
                            CornerRadius="2">
                        <StackPanel>
                            <Image x:Name="EncodeCutImage2"
                                   Height="88"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                            <TextBlock x:Name="EncodeCutLabel2"
                                       Margin="0,3,0,2"
                                       HorizontalAlignment="Center"
                                       FontSize="10"
                                       Foreground="#FF23313E" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border x:Name="ZoomBadgeBorder"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="50,8,0,0"
                    Padding="6,3"
                    Background="#88F4F7FB"
                    BorderBrush="#FFBDC7D2"
                    BorderThickness="1"
                    CornerRadius="3"
                    IsHitTestVisible="False">
                <TextBlock x:Name="ZoomPercentText"
                           Foreground="#FF23313E"
                           FontSize="11"
                           Text="Zoom: 100%" />
            </Border>

            <Grid x:Name="EmbeddedBusyOverlay"
                  Panel.ZIndex="500"
                  Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                  IsHitTestVisible="True">
                <Grid.Background>
                    <RadialGradientBrush GradientOrigin="0.5,0.5"
                                         Center="0.5,0.5"
                                         RadiusX="0.85"
                                         RadiusY="0.85">
                        <GradientStop Color="#AA050810"
                                      Offset="0" />
                        <GradientStop Color="#CC020408"
                                      Offset="0.55" />
                        <GradientStop Color="#EE010204"
                                      Offset="1" />
                    </RadialGradientBrush>
                </Grid.Background>

                <dcmcontrols:DcmBusyOverlayPanel HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   StatusText="{Binding StatusText}"
                                                   LoadProgress="{Binding LoadProgress, Mode=OneWay}"
                                                   ProgressPercentText="{Binding LoadProgressPercentText}"
                                                   CancelClick="BusyOverlayCancelButton_OnClick" />
            </Grid>
        </Grid>
    </Grid>
</Window>
