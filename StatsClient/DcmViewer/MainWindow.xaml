<Window x:Class="DCMViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
        xmlns:local="clr-namespace:DCMViewer"
        xmlns:vm="clr-namespace:DCMViewer.ViewModels"
        xmlns:usercontrols="clr-namespace:StatsClient.UserControls"
        xmlns:dcmcontrols="clr-namespace:DCMViewer.Controls"
        mc:Ignorable="d"
        Title="DCM Viewer"
        Height="920"
        Width="1200"
        MinHeight="500"
        MinWidth="800"
        AllowDrop="True"
        PreviewDragOver="Window_PreviewDragOver"
        Drop="Window_Drop">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:WatermarkSizeConverter x:Key="WatermarkSizeConverter" />
        <local:BindingProxy x:Key="ViewerBindingProxy" />

        <!-- Slider track segment buttons -->
        <Style x:Key="SliderRepeatButton"
               TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle"
                    Value="True" />
            <Setter Property="Focusable"
                    Value="False" />
            <Setter Property="IsTabStop"
                    Value="False" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Height="3"
                                VerticalAlignment="Center"
                                Background="{TemplateBinding Background}"
                                CornerRadius="1.5" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SliderRepeatButtonVertical"
               TargetType="RepeatButton"
               BasedOn="{StaticResource SliderRepeatButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Width="3"
                                HorizontalAlignment="Center"
                                Background="{TemplateBinding Background}"
                                CornerRadius="1.5" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Round slider thumb -->
        <Style x:Key="SliderThumb"
               TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle"
                    Value="True" />
            <Setter Property="Width"
                    Value="22" />
            <Setter Property="Height"
                    Value="22" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse x:Name="Knob"
                                 Fill="#FFD0D9E2"
                                 Stroke="#FF7C8FA3"
                                 StrokeThickness="1" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Knob"
                                        Property="Fill"
                                        Value="#FFE8EDF3" />
                                <Setter TargetName="Knob"
                                        Property="Stroke"
                                        Value="#FFA0B4C8" />
                            </Trigger>
                            <Trigger Property="IsDragging"
                                     Value="True">
                                <Setter TargetName="Knob"
                                        Property="Fill"
                                        Value="#FFB8C8D8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopRightSliderThumb"
               TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle"
                    Value="True" />
            <Setter Property="Width"
                    Value="20" />
            <Setter Property="Height"
                    Value="20" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Image Width="20"
                               Height="20"
                               Stretch="Uniform"
                               Source="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Base nice slider template (appearance only) -->
        <Style x:Key="NiceSlider"
               TargetType="Slider">
            <Setter Property="OverridesDefaultStyle"
                    Value="True" />
            <Setter Property="Height"
                    Value="40" />
            <Setter Property="VerticalAlignment"
                    Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="40"
                              VerticalAlignment="Center"
                              Background="Transparent">
                            <Track x:Name="PART_Track"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderRepeatButton}"
                                                  Background="#FF5A7090" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderRepeatButton}"
                                                  Background="#FF38475A" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumb}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- File-list opacity slider (inherits NiceSlider, adds range + min-width) -->
        <Style x:Key="NiceOpacitySlider"
               TargetType="Slider"
               BasedOn="{StaticResource NiceSlider}">
            <Setter Property="Minimum"
                    Value="0" />
            <Setter Property="Maximum"
                    Value="1" />
            <Setter Property="SmallChange"
                    Value="0.02" />
            <Setter Property="LargeChange"
                    Value="0.1" />
            <Setter Property="MinWidth"
                    Value="110" />
        </Style>

        <Style x:Key="TopRightOpacitySlider"
               TargetType="Slider"
               BasedOn="{StaticResource NiceOpacitySlider}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="40"
                              VerticalAlignment="Center"
                              Background="Transparent">
                            <Track x:Name="PART_Track"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderRepeatButton}"
                                                  Background="#FF5A7090" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderRepeatButton}"
                                                  Background="#FF38475A" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource TopRightSliderThumb}"
                                           Tag="{TemplateBinding Tag}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeaderSlider"
               TargetType="Slider"
               BasedOn="{StaticResource NiceSlider}">
            <Setter Property="Height"
                    Value="22" />
            <Setter Property="VerticalAlignment"
                    Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="22"
                              VerticalAlignment="Center"
                              Background="Transparent">
                            <Track x:Name="PART_Track"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderRepeatButton}"
                                                  Background="#FF5A7090" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderRepeatButton}"
                                                  Background="#FF38475A" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumb}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NiceVerticalSlider"
               TargetType="Slider">
            <Setter Property="OverridesDefaultStyle"
                    Value="True" />
            <Setter Property="Width"
                    Value="34" />
            <Setter Property="Height"
                    Value="116" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Width="34"
                              Height="116"
                              Background="Transparent">
                            <Track x:Name="PART_Track"
                                   Orientation="Vertical"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,4">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderRepeatButtonVertical}"
                                                  Background="#FF5A7090" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderRepeatButtonVertical}"
                                                  Background="#FF38475A" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumb}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton"
               TargetType="Button">
            <Setter Property="Width"
                    Value="38" />
            <Setter Property="Height"
                    Value="32" />
            <Setter Property="FontSize"
                    Value="15" />
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="Margin"
                    Value="0,0,0,6" />
            <Setter Property="Background"
                    Value="#FFEDF2F8" />
            <Setter Property="BorderBrush"
                    Value="#FFBDC7D2" />
            <Setter Property="BorderThickness"
                    Value="1" />
        </Style>

        <Style x:Key="SculptKnobSlider"
               TargetType="Slider"
               BasedOn="{StaticResource NiceSlider}">
            <Setter Property="Height"
                    Value="28" />
            <Setter Property="VerticalAlignment"
                    Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="28"
                              VerticalAlignment="Center"
                              Background="Transparent">
                            <Track x:Name="PART_Track"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderRepeatButton}"
                                                  Background="#FF5A7090" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderRepeatButton}"
                                                  Background="#FF38475A" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource TopRightSliderThumb}"
                                           Tag="{TemplateBinding Tag}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SculptPanelIconButton"
               TargetType="Button"
               BasedOn="{StaticResource IconButton}">
            <Setter Property="Width"
                    Value="38" />
            <Setter Property="Height"
                    Value="38" />
            <Setter Property="Margin"
                    Value="0,0,4,0" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Center" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsEnabled"
                         Value="False">
                    <Setter Property="Opacity"
                            Value="0.38" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SculptToolSelectButton"
               TargetType="Button"
               BasedOn="{StaticResource SculptPanelIconButton}">
            <Setter Property="Background"
                    Value="#FFEDF2F8" />
            <Setter Property="BorderBrush"
                    Value="#FFBDC7D2" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#FFE8EDF3" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RoundCheckBox"
               TargetType="CheckBox">
            <Setter Property="OverridesDefaultStyle"
                    Value="True" />
            <Setter Property="Width"
                    Value="16" />
            <Setter Property="Height"
                    Value="16" />
            <Setter Property="VerticalAlignment"
                    Value="Center" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="16"
                              Height="16">
                            <Border x:Name="Ring"
                                    CornerRadius="8"
                                    BorderThickness="1.5"
                                    BorderBrush="#FF4A5F72"
                                    Background="#FFEDF2F8" />
                            <Path x:Name="CheckMark"
                                    Data="M 4,8 L 7,11 L 12,5"
                                    Stroke="#FF2E9B49"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Visibility="Collapsed" />
                                <Path x:Name="EncryptedMark"
                                    Data="M 5,5 L 11,11 M 11,5 L 5,11"
                                    Stroke="#FF7A1F33"
                                    StrokeThickness="2"
                                    StrokeStartLineCap="Round"
                                    StrokeEndLineCap="Round"
                                    Visibility="Collapsed" />
                            <Path x:Name="FailedMark"
                                  Data="M 5,5 L 11,11 M 11,5 L 5,11"
                                  Stroke="#FF7A1F33"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="CheckMark"
                                    Property="Visibility"
                                    Value="Visible" />
                                <Setter TargetName="Ring"
                                    Property="Background"
                                    Value="#FFE8F6EC" />
                                <Setter TargetName="Ring"
                                    Property="BorderBrush"
                                    Value="#FF2E9B49" />
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Ring"
                                        Property="BorderBrush"
                                        Value="#FF7A9EC0" />
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="Ring"
                                        Property="Opacity"
                                        Value="0.45" />
                                <Setter TargetName="CheckMark"
                                        Property="Opacity"
                                        Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FileRoundCheckBox"
               TargetType="CheckBox"
               BasedOn="{StaticResource RoundCheckBox}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPackageLocked}"
                             Value="True">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="CheckBox">
                                <Grid Width="16"
                                      Height="16">
                                    <Border x:Name="Ring"
                                            CornerRadius="8"
                                            BorderThickness="1.5"
                                            BorderBrush="#FF7A1F33"
                                            Background="#FFF5E6EA" />
                                    <Path x:Name="EncryptedMark"
                                          Data="M 5,5 L 11,11 M 11,5 L 5,11"
                                          Stroke="#FF7A1F33"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Visibility="Collapsed" />
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked"
                                             Value="True">
                                        <Setter TargetName="EncryptedMark"
                                                Property="Visibility"
                                                Value="Visible" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter TargetName="Ring"
                                                Property="BorderBrush"
                                                Value="#FF9E3A4A" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsLoadFailed}"
                             Value="True">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="CheckBox">
                                <Grid Width="16"
                                      Height="16">
                                    <Border x:Name="Ring"
                                            CornerRadius="8"
                                            BorderThickness="1.5"
                                            BorderBrush="#FF7A1F33"
                                            Background="#FFF5E6EA" />
                                    <Path x:Name="FailedMark"
                                          Data="M 5,5 L 11,11 M 11,5 L 5,11"
                                          Stroke="#FF7A1F33"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Visibility="Collapsed" />
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked"
                                             Value="True">
                                        <Setter TargetName="FailedMark"
                                                Property="Visibility"
                                                Value="Visible" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter TargetName="Ring"
                                                Property="BorderBrush"
                                                Value="#FF9E3A4A" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <ControlTemplate x:Key="CategoryGroupFailedCheckBoxTemplate"
                         TargetType="CheckBox">
            <Grid Width="16"
                  Height="16">
                <Border x:Name="Ring"
                        CornerRadius="8"
                        BorderThickness="1.5"
                        BorderBrush="#FF7A1F33"
                        Background="#FFF5E6EA" />
                <Path x:Name="FailedMark"
                      Data="M 5,5 L 11,11 M 11,5 L 5,11"
                      Stroke="#FF7A1F33"
                      StrokeThickness="2"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Visibility="Collapsed" />
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsChecked"
                         Value="True">
                    <Setter TargetName="FailedMark"
                            Property="Visibility"
                            Value="Visible" />
                </Trigger>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter TargetName="Ring"
                            Property="BorderBrush"
                            Value="#FF9E3A4A" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="FailedOpacitySliderTemplate"
                         TargetType="Slider">
            <Grid Height="40"
                  VerticalAlignment="Center"
                  Background="Transparent">
                <Track x:Name="PART_Track"
                       VerticalAlignment="Center">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource SliderRepeatButton}"
                                      Background="#FF4A1320" />
                    </Track.DecreaseRepeatButton>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource SliderRepeatButton}"
                                      Background="#FF2B0A12" />
                    </Track.IncreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource SliderThumb}" />
                    </Track.Thumb>
                </Track>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="TopRightFailedOpacitySliderTemplate"
                         TargetType="Slider">
            <Grid Height="40"
                  VerticalAlignment="Center"
                  Background="Transparent">
                <Track x:Name="PART_Track"
                       VerticalAlignment="Center">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource SliderRepeatButton}"
                                      Background="#FF4A1320" />
                    </Track.DecreaseRepeatButton>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource SliderRepeatButton}"
                                      Background="#FF2B0A12" />
                    </Track.IncreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource TopRightSliderThumb}"
                               Tag="{TemplateBinding Tag}" />
                    </Track.Thumb>
                </Track>
            </Grid>
        </ControlTemplate>

         <Style x:Key="TopRightOverlayFadeStyle"
             TargetType="FrameworkElement">
            <Setter Property="Opacity"
                    Value="1" />
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <StopStoryboard BeginStoryboardName="TopRightFadeOutStoryboard" />
                    <BeginStoryboard Name="TopRightFadeInStoryboard">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="1"
                                             Duration="0:0:0.15" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>

                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard Name="TopRightFadeOutStoryboard">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             BeginTime="0:0:10"
                                             To="0.15"
                                             Duration="0:0:0.9" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScanArchSectionHeaderText"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#FF5A6B7D" />
            <Setter Property="Background"
                    Value="#FFE3E7EA" />
            <Setter Property="Padding"
                    Value="6,2,8,2" />
            <Setter Property="FontSize"
                    Value="9" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Margin"
                    Value="2,8,0,2" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HideLayerLabels}"
                             Value="True">
                    <Setter Property="Visibility"
                            Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="LoadedFileLayerRowTemplate">
            <Grid Margin="0,2,0,2">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility"
                                Value="Visible" />
                        <Setter Property="Margin"
                                Value="0,2,0,2" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding UseCategoryGroupControl}"
                                               Value="True" />
                                    <Condition Binding="{Binding Category}"
                                               Value="{x:Static vm:MeshCategory.Restoration}" />
                                    <Condition Binding="{Binding Data.ShowRestorationGroupExpander, Source={StaticResource ViewerBindingProxy}}"
                                               Value="True" />
                                    <Condition Binding="{Binding Data.IsRestorationGroupExpanded, Source={StaticResource ViewerBindingProxy}}"
                                               Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding UseCategoryGroupControl}"
                                               Value="True" />
                                    <Condition Binding="{Binding Category}"
                                               Value="{x:Static vm:MeshCategory.Abutment}" />
                                    <Condition Binding="{Binding Data.ShowAbutmentGroupExpander, Source={StaticResource ViewerBindingProxy}}"
                                               Value="True" />
                                    <Condition Binding="{Binding Data.IsAbutmentGroupExpanded, Source={StaticResource ViewerBindingProxy}}"
                                               Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="{Binding Data.LayerRowLabelColumnWidth, Source={StaticResource ViewerBindingProxy}}" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="{Binding Data.LayerRowSliderColumnWidth, Source={StaticResource ViewerBindingProxy}}" />
                </Grid.ColumnDefinitions>

                <CheckBox Grid.Column="0"
                          IsEnabled="{Binding IsLayerCheckBoxEnabled}"
                          IsChecked="{Binding IsVisible, Mode=TwoWay}">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox"
                               BasedOn="{StaticResource FileRoundCheckBox}">
                            <Setter Property="VerticalAlignment"
                                    Value="Center" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding UseCategoryGroupControl}"
                                                   Value="True" />
                                        <Condition Binding="{Binding Category}"
                                                   Value="{x:Static vm:MeshCategory.Restoration}" />
                                        <Condition Binding="{Binding Data.ShowRestorationGroupExpander, Source={StaticResource ViewerBindingProxy}}"
                                                   Value="True" />
                                        <Condition Binding="{Binding Data.IsRestorationGroupExpanded, Source={StaticResource ViewerBindingProxy}}"
                                                   Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Margin"
                                            Value="24,0,0,0" />
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding UseCategoryGroupControl}"
                                                   Value="True" />
                                        <Condition Binding="{Binding Category}"
                                                   Value="{x:Static vm:MeshCategory.Abutment}" />
                                        <Condition Binding="{Binding Data.ShowAbutmentGroupExpander, Source={StaticResource ViewerBindingProxy}}"
                                                   Value="True" />
                                        <Condition Binding="{Binding Data.IsAbutmentGroupExpanded, Source={StaticResource ViewerBindingProxy}}"
                                                   Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Margin"
                                            Value="24,0,0,0" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </CheckBox.Style>
                </CheckBox>

                <Border Grid.Column="2"
                        VerticalAlignment="Center"
                        CornerRadius="2"
                        Padding="4,1,4,1"
                        MinWidth="0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background"
                                    Value="#FF2A323D" />
                            <Setter Property="BorderBrush"
                                    Value="Transparent" />
                            <Setter Property="BorderThickness"
                                    Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPackageLocked}"
                                             Value="True">
                                    <Setter Property="Background"
                                            Value="#FF800000" />
                                    <Setter Property="BorderBrush"
                                            Value="#FFA33A3A" />
                                </DataTrigger>
