<UserControl x:Class="DCMViewer.Controls.DcmBusyOverlayPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="320"
             d:DesignWidth="420"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="FuturisticProgressBar"
               TargetType="ProgressBar">
            <Setter Property="Height" Value="6" />
            <Setter Property="Background" Value="#332A3544" />
            <Setter Property="Foreground" Value="#FF34D9F5" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid MinHeight="{TemplateBinding Height}">
                            <Border x:Name="PART_Track"
                                    CornerRadius="3"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#4434D9F5"
                                    BorderThickness="1" />
                            <Border x:Name="PART_Indicator"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0"
                                                      BlurRadius="14"
                                                      Color="#FF34D9F5"
                                                      Opacity="0.85" />
                                </Border.Effect>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="OrbitRingOuter"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                     From="0"
                                     To="360"
                                     Duration="0:0:4.2" />
                    <DoubleAnimation Storyboard.TargetName="OrbitRingMid"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                     From="360"
                                     To="0"
                                     Duration="0:0:2.8" />
                    <DoubleAnimation Storyboard.TargetName="OrbitRingInner"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                     From="0"
                                     To="360"
                                     Duration="0:0:1.6" />
                    <DoubleAnimation Storyboard.TargetName="CorePulse"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.45"
                                     To="1"
                                     AutoReverse="True"
                                     Duration="0:0:0.9" />
                    <DoubleAnimation Storyboard.TargetName="CorePulse"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                     From="0.88"
                                     To="1.08"
                                     AutoReverse="True"
                                     Duration="0:0:0.9" />
                    <DoubleAnimation Storyboard.TargetName="CorePulse"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                     From="0.88"
                                     To="1.08"
                                     AutoReverse="True"
                                     Duration="0:0:0.9" />
                    <DoubleAnimation Storyboard.TargetName="ScanLine"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="-120"
                                     To="120"
                                     Duration="0:0:2.4"
                                     AutoReverse="True" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Border Width="380"
            Padding="28,26"
            CornerRadius="16"
            BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">
                <GradientStop Color="#E610141C"
                              Offset="0" />
                <GradientStop Color="#D80C1018"
                              Offset="0.55" />
                <GradientStop Color="#CC121826"
                              Offset="1" />
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">
                <GradientStop Color="#8834D9F5"
                              Offset="0" />
                <GradientStop Color="#4434D9F5"
                              Offset="0.5" />
                <GradientStop Color="#886B8CFF"
                              Offset="1" />
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0"
                              BlurRadius="36"
                              Color="#5534D9F5"
                              Opacity="0.55" />
        </Border.Effect>

        <Grid ClipToBounds="True">
            <Rectangle x:Name="ScanLine"
                       Height="48"
                       VerticalAlignment="Center"
                       Opacity="0.06"
                       RenderTransformOrigin="0.5,0.5">
                <Rectangle.RenderTransform>
                    <TranslateTransform Y="-120" />
                </Rectangle.RenderTransform>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="0,1">
                        <GradientStop Color="#0034D9F5"
                                      Offset="0" />
                        <GradientStop Color="#5534D9F5"
                                      Offset="0.5" />
                        <GradientStop Color="#0034D9F5"
                                      Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <StackPanel HorizontalAlignment="Center">
                <Grid Width="112"
                      Height="112"
                      Margin="0,0,0,18">
                    <Ellipse Width="112"
                             Height="112"
                             Opacity="0.18">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#5534D9F5"
                                              Offset="0" />
                                <GradientStop Color="#0034D9F5"
                                              Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <Ellipse x:Name="OrbitRingOuter"
                             Width="98"
                             Height="98"
                             Stroke="#6634D9F5"
                             StrokeThickness="1.2"
                             StrokeDashArray="3 9"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform Angle="0" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Ellipse x:Name="OrbitRingMid"
                             Width="74"
                             Height="74"
                             Stroke="#886B8CFF"
                             StrokeThickness="1.4"
                             StrokeDashArray="2 6"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform Angle="0" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Ellipse x:Name="OrbitRingInner"
                             Width="50"
                             Height="50"
                             Stroke="#AA34D9F5"
                             StrokeThickness="1.6"
                             StrokeDashArray="1.5 4"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform Angle="0" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Ellipse x:Name="CorePulse"
                             Width="14"
                             Height="14"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <ScaleTransform ScaleX="1"
                                            ScaleY="1" />
                        </Ellipse.RenderTransform>
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#FF9AF4FF"
                                              Offset="0" />
                                <GradientStop Color="#FF34D9F5"
                                              Offset="0.55" />
                                <GradientStop Color="#0034D9F5"
                                              Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.Effect>
                            <DropShadowEffect ShadowDepth="0"
                                              BlurRadius="18"
                                              Color="#FF34D9F5"
                                              Opacity="0.95" />
                        </Ellipse.Effect>
                    </Ellipse>
                </Grid>

                <TextBlock Text="PROCESSING"
                           HorizontalAlignment="Center"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="#6634D9F5" />

                <TextBlock Text="{Binding StatusText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Margin="0,8,0,0"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="320"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#FFE8F4FF"
                           LineHeight="22">
                    <TextBlock.Effect>
                        <DropShadowEffect ShadowDepth="0"
                                          BlurRadius="8"
                                          Color="#5534D9F5"
                                          Opacity="0.35" />
                    </TextBlock.Effect>
                </TextBlock>

                <ProgressBar Style="{StaticResource FuturisticProgressBar}"
                             Width="260"
                             Margin="0,20,0,0"
                             Minimum="0"
                             Maximum="1"
                             Value="{Binding LoadProgress, RelativeSource={RelativeSource AncestorType=UserControl}}" />

                <Grid Width="260"
                      Margin="0,10,0,0">
                    <TextBlock Text="{Binding ProgressPercentText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               HorizontalAlignment="Left"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#FF34D9F5"
                               FontFamily="Segoe UI" />
                    <TextBlock Text="complete"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"
                               Margin="0,0,0,3"
                               FontSize="11"
                               Foreground="#668898A8"
                               FontWeight="SemiBold" />
                </Grid>

                <Button x:Name="CancelButton"
                        Width="148"
                        Height="36"
                        Margin="0,22,0,0"
                        Content="Cancel"
                        Cursor="Hand"
                        Click="CancelButton_OnClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    CornerRadius="8"
                                    Background="#22101820"
                                    BorderBrush="#5534D9F5"
                                    BorderThickness="1"
                                    Padding="12,6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root"
                                            Property="Background"
                                            Value="#3334D9F5" />
                                    <Setter TargetName="Root"
                                            Property="BorderBrush"
                                            Value="#AA34D9F5" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root"
                                            Property="Background"
                                            Value="#5534D9F5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Foreground>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,0">
                            <GradientStop Color="#FFE8F4FF"
                                          Offset="0" />
                            <GradientStop Color="#FF9AF4FF"
                                          Offset="1" />
                        </LinearGradientBrush>
                    </Button.Foreground>
                    <Button.FontWeight>SemiBold</Button.FontWeight>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
