<UserControl x:Class="DCMViewer.Controls.DcmViewerCanvasComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="http://helix-toolkit.org/wpf"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1000">
    <Grid x:Name="WatermarkCanvas">
        <Image x:Name="LogoImage"
               MaxWidth="512"
               MaxHeight="512"
               Width="420"
               Height="420"
               Opacity="0.03"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               IsHitTestVisible="False"
               Panel.ZIndex="0" />

        <TextBlock x:Name="WatermarkTextBlock"
                   Text="AmL"
                   FontSize="80"
                   FontWeight="SemiBold"
                   Foreground="#FFB8A35C"
                   Opacity="0.05"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"
                   Panel.ZIndex="0">
            <TextBlock.Effect>
                <DropShadowEffect ShadowDepth="0"
                                  BlurRadius="26"
                                  Opacity="0.16"
                                  Color="#FF000000" />
            </TextBlock.Effect>
        </TextBlock>

        <h:HelixViewport3D x:Name="Viewport"
                           ShowViewCube="True"
                           ShowCoordinateSystem="True"
                           IsRotationEnabled="True"
                           CameraRotationMode="Trackball"
                           RotateGesture="RightClick"
                           IsPanEnabled="True"
                           IsZoomEnabled="True"
                           RotateAroundMouseDownPoint="False"
                           ZoomExtentsWhenLoaded="True"
                           UseLayoutRounding="True"
                           RenderOptions.CachingHint="Cache"
                           Background="Transparent">

            <h:HelixViewport3D.Camera>
                <PerspectiveCamera Position="{Binding CameraPosition}"
                                   LookDirection="{Binding CameraLookDirection}"
                                   UpDirection="{Binding CameraUpDirection}"
                                   FieldOfView="45" />
            </h:HelixViewport3D.Camera>

            <h:CuttingPlaneGroup x:Name="SectionCutGroup"
                                 IsEnabled="False"
                                 Content="{Binding ModelGroup}" />

            <ModelVisual3D x:Name="SectionPlaneVisual" />
            <h:LinesVisual3D x:Name="SectionPlaneOutlineVisual"
                             IsRendering="False"
                             Thickness="1.0"
                             Color="#FF15459F" />

            <h:LinesVisual3D x:Name="MeasurementLine"
                             Thickness="2.4"
                             Color="#FF1F6FEB"
                             IsRendering="False" />

            <h:BillboardTextVisual3D x:Name="MeasurementText"
                                     IsRendering="False"
                                     Background="#DDF5F9FF"
                                     BorderBrush="#FF8BA1B8"
                                     BorderThickness="1"
                                     Foreground="#FF1A2A3A"
                                     Padding="6,3"
                                     FontSize="13"
                                     FontWeight="SemiBold"
                                     Text="" />
        </h:HelixViewport3D>
    </Grid>
</UserControl>
