                                       FontWeight="Normal"
                                       Foreground="{DynamicResource GreenColor}"
                                       HorizontalAlignment="Left"
                                       Grid.Row="1"
                                       Grid.Column="1"
                                       Margin="0,0,0,4" />

                            <TextBlock Text="At: "
                                       HorizontalAlignment="Right"
                                       Grid.Row="2"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       FontWeight="Thin"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="{Binding DesignDate, Converter={StaticResource DateTimeStringToUSADateTimeConverter}}"
                                       FontWeight="Normal"
                                       Foreground="{DynamicResource BlackColor}"
                                       HorizontalAlignment="Left"
                                       Grid.Row="2"
                                       Grid.Column="1"
                                       Margin="0,0,0,4" />

                            <TextBlock Text="But Paid to: "
                                       HorizontalAlignment="Right"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Grid.Row="3"
                                       FontWeight="Thin" />
                            <TextBlock Text="{Binding GotPaid}"
                                       FontWeight="Normal"
                                       Foreground="{DynamicResource RedColor}"
                                       HorizontalAlignment="Left"
                                       Grid.Row="3"
                                       Grid.Column="1" />


                            <TextBlock Text="Invoice Date: "
                                       HorizontalAlignment="Right"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Grid.Row="4"
                                       FontWeight="Thin" />
                            <TextBlock Text="{Binding LxInvoiceDate}"
                                       FontWeight="Normal"
                                       Foreground="{DynamicResource BlackColor}"
                                       HorizontalAlignment="Left"
                                       Grid.Row="4"
                                       Grid.Column="1" />

                            <TextBlock Text="From range of: "
                                       HorizontalAlignment="Right"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Grid.Row="5"
                                       FontWeight="Thin" />
                            <TextBlock Text="{Binding LxInvoiceDateRange}"
                                       FontWeight="Normal"
                                       Foreground="{DynamicResource BlackColor}"
                                       HorizontalAlignment="Left"
                                       Grid.Row="5"
                                       Grid.Column="1" />

                            <TextBlock Text="Labnext ID: "
                                       HorizontalAlignment="Right"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Grid.Row="6"
                                       FontWeight="Thin" />
                            <TextBlock Text="{Binding LxLabnextID}"
                                       FontWeight="Normal"
                                       Foreground="{DynamicResource BlueColor}"
                                       HorizontalAlignment="Left"
                                       Cursor="Hand"
                                       Grid.Row="6"
                                       Grid.Column="1">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="MouseDown">
                                        <i:InvokeCommandAction Command="{Binding DataContext.LabnextIdClickedCommand, 
                                                                         RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListView}}}"
                                                               CommandParameter="{Binding LxLabnextID}" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="ItemsControl.AlternationIndex"
                                 Value="1">
                            <Setter TargetName="Border"
                                    Property="Background"
                                    Value="{StaticResource LvItemCasesPaidForWrongDesignerList_AlternateRowBackground}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>



    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Themes/ControlStyles.xaml" />
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
