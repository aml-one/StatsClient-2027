                                                                    FontWeight="SemiBold"
                                                                    Fill="{Binding PanColor}"
                                                                    StrokeThickness="0.35"
                                                                    Text="{Binding PanNumber}"
                                                                    VerticalAlignment="Top"
                                                                    HorizontalAlignment="Left"
                                                                    TextTrimming="WordEllipsis"
                                                                    Margin="17,1,0,0" />

                                        </Grid>
                                    </Border>
                                </Grid>


                            </StackPanel>











                            <!-- Customer & Patient info -->
                            <StackPanel Orientation="Vertical"
                                        Grid.Column="1"
                                        Margin="5,0,10,0"
                                        VerticalAlignment="Top">
                                <TextBlock Text="{Binding Customer}"
                                           Foreground="{DynamicResource LvItemDetailedNew_PrimaryForeground}"
                                           FontWeight="SemiBold"
                                           FontSize="11"
                                           TextWrapping="WrapWithOverflow"
                                           Margin="0,0,0,0"
                                           Padding="0"
                                           VerticalAlignment="Top" />


                                <StackPanel Orientation="Horizontal"
                                            Margin="0,-2,0,0"
                                            VerticalAlignment="Bottom">

                                    <TextBlock Text="{Binding Patient_FirstName}"
                                               Foreground="{DynamicResource LvItem3ShapePayment_PatientFirstForeground}"
                                               FontSize="16"
                                               VerticalAlignment="Top"
                                               FontWeight="SemiBold"
                                               MaxWidth="150"
                                               Margin="0,1,5,0"
                                               TextWrapping="WrapWithOverflow"
                                               Visibility="{Binding Patient_FirstName, Converter={StaticResource EmptyToCollapsedConverter}}" />

                                    <TextBlock Text="{Binding Patient_LastName}"
                                               Foreground="{DynamicResource LvItem3ShapePayment_PatientLastForeground}"
                                               FontSize="16"
                                               Margin="0,1,0,0"
                                               FontWeight="SemiBold"
                                               MaxWidth="150"
                                               VerticalAlignment="Top"
                                               TextWrapping="WrapWithOverflow" />



                                </StackPanel>
                            </StackPanel>




                            <!-- Buttons -->
                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Top"
                                        d:Visibility="Visible"
                                        Visibility="Hidden"
                                        Margin="0,2,0,0"
                                        x:Name="tsButtonPanel">
                                <Grid HorizontalAlignment="Right">

                                    <Button Width="28"
                                            Height="28"
                                            Background="{DynamicResource LvItemDetailedNew_ButtonBackground}"
                                            Margin="4,0,4,0"
                                            Grid.Column="0"
                                            ToolTip="Assign Labnext order to this 3Shape Order"
                                            Style="{StaticResource ThreeShapeListviewButton}">
                                        <Image Source="\Images\ToolBar\assign.png"
                                               Width="31"
                                               Height="31" />
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="PreviewMouseDown">
                                                <i:InvokeCommandAction Command="{Binding DataContext.AssignOrderToLabnextCaseCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListView}}}"
                                                                       CommandParameter="{Binding .}" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </Button>


                                </Grid>
                            </StackPanel>



                            <!-- Designer -->
                            <StackPanel Grid.Column="3"
                                        VerticalAlignment="Top"
                                        HorizontalAlignment="Center"
                                        Margin="0,8,20,0">


                                <TextBlock Text="{Binding ExtOrderID}"
                                           Foreground="{DynamicResource LvItemDetailedNew_DesignerForeground}"
                                           FontSize="12"
                                           FontWeight="DemiBold"
                                           VerticalAlignment="Top"
                                           Width="135"
                                           TextWrapping="WrapWithOverflow" />

                            </StackPanel>


                            <!-- Items -->
                            <StackPanel Grid.Column="4"
                                        VerticalAlignment="Top"
                                        MinWidth="150"
                                        Margin="5,2,10,0">
                                <TextBlock Text="{Binding Items}"
                                           Foreground="{DynamicResource LvItem3ShapePayment_ItemsForeground}"
                                           VerticalAlignment="Top"
                                           Margin="0,0,0,0"
                                           Padding="0"
                                           FontWeight="Thin"
                                           FontSize="22"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <!-- OrderID & Creation date -->
                            <Ellipse Width="33"
                                     Height="33"
                                     Margin="3,0,2,0"
                                     Grid.Column="5"
                                     VerticalAlignment="Top"
                                     x:Name="Icon">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{Binding ImageSource}"
                                                RenderOptions.BitmapScalingMode="Fant" />
                                </Ellipse.Fill>
                            </Ellipse>
                            <StackPanel VerticalAlignment="Top"
                                        Height="32"
                                        Orientation="Horizontal"
                                        Grid.Column="6"
                                        Margin="4,0,20,0">
                                <StackPanel Orientation="Vertical"
                                            Margin="0,2,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding IntOrderID}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource LvItemDetailedNew_PrimaryForeground}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock d:Text="(tool tip text)"
                                                   x:Name="ToolTipText"
                                                   FontSize="9"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="5,0,0,0" />

                                    </StackPanel>


                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,1,0,0">


                                        <Label Content="Created:"
                                               FontSize="10"
                                               Foreground="{DynamicResource LvItemDetailedNew_LabelForeground}"
                                               FontWeight="Normal"
                                               Padding="0,0,4,0" />
                                        <TextBlock Text="{Binding MaxCreateDateFriendly}"
                                                   Foreground="{DynamicResource LvItem3ShapePayment_CreatedDateForeground}"
                                                   FontSize="12"
                                                   Margin="0,-2,0,0"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="WrapWithOverflow" />
                                    </StackPanel>

                                </StackPanel>
                            </StackPanel>


                        </Grid>
                    </Border>


                    <ControlTemplate.Triggers>
                        <Trigger Property="ItemsControl.AlternationIndex"
                                 Value="1">
                            <!--Setter TargetName="Item"
                                    Property="Background"
                                    Value="{StaticResource LvItemDetailedNew_AlternateBackground}" /-->
                        </Trigger>




                        <DataTrigger Binding="{Binding PanColor}"
                                     Value="{StaticResource LvItem3ShapeOrderModelListForPaymentIssue_ItemBackground}">
                            <Setter TargetName="Item"
                                    Property="Background"
                                    Value="{StaticResource LvItemDetailedNew_WarningBackground}" />
                            <Setter TargetName="ToolTipText"
                                    Property="Text"
                                    Value="Pan is not registered!" />
                            <Setter TargetName="ToolTipText"
                                    Property="Foreground"
                                    Value="{StaticResource LvItemDetailedNew_TooltipGreenForeground}" />
                            <Setter TargetName="brdPanColor"
                                    Property="BorderBrush"
                                    Value="{StaticResource LvItem3ShapeOrderModelListForPaymentIssue_ItemBackground}" />
                        </DataTrigger>

                        <DataTrigger Binding="{Binding PanNumber}"
                                     Value="">
                            <Setter TargetName="Item"
                                    Property="Background"
                                    Value="{StaticResource LvItemDetailedNew_WarningBackground}" />
                            <Setter TargetName="ToolTipText"
                                    Property="Text"
                                    Value="There is no pan number set!" />
                            <Setter TargetName="ToolTipText"
                                    Property="Foreground"
                                    Value="{StaticResource LvItemDetailedNew_TooltipOrangeForeground}" />
                            <Setter TargetName="brdPanColor"
                                    Property="BorderBrush"
                                    Value="{StaticResource LvItem3ShapeOrderModelListForPaymentIssue_ItemBackground}" />
                        </DataTrigger>

                        

                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter Property="BorderBrush"
                                    Value="{StaticResource LvItemDetailedNew_PanHoverBorderBrush}"
                                    TargetName="Item" />
                            <Setter Property="BorderThickness"
                                    Value="1,2,1,2"
                                    TargetName="Item" />
                            <Setter Property="Margin"
                                    Value="0,0,0,2"
                                    TargetName="Item" />
                            <!--Setter Property="Background"
                                    Value="{StaticResource LvItemDetailedNew_HoverBackground}"
                                    TargetName="Item" /-->
                            <Setter Property="Cursor"
                                    Value="Hand"
                                    TargetName="Item" />
                            <Setter Property="Visibility"
                                    Value="Visible"
                                    TargetName="tsButtonPanel" />
                        </Trigger>



                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- LvItemIssues -->
    <Style TargetType="ListViewItem"
           x:Key="LvItemIssues">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border x:Name="IssueItem"
                            BorderThickness="1"
                            Height="26"
                            Background="{Binding Color}"
                            Tag="{Binding OrderID}">
                        <Border.InputBindings>
                            <MouseBinding Gesture="LeftDoubleClick"
                                          Command="{Binding DataContext.SearchForOrderByOrderIssueClickCommand,
                                                            RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListView}}}" />
                        </Border.InputBindings>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding ElementName=lvIssuesOrderID, Path=Width}" />
                                <ColumnDefinition Width="{Binding ElementName=lvIssuesSkipReason, Path=Width}" />
                            </Grid.ColumnDefinitions>


                            <TextBlock Text="{Binding OrderID}"
                                       Grid.Column="0"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="{DynamicResource LvItemIssues_PrimaryForeground}"
                                       Margin="5,0,20,0"
                                       TextTrimming="CharacterEllipsis" />


                            <TextBlock Text="{Binding IssueDescription}"
                                       Grid.Column="1"
                                       FontWeight="Normal"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="{DynamicResource LvItemIssues_PrimaryForeground}"
                                       Margin="5,0,0,0"
                                       TextTrimming="CharacterEllipsis" />

                        </Grid>

                    </Border>


                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter Property="BorderBrush"
                                    Value="{StaticResource LvItemIssues_HoverBorderBrush}"
                                    TargetName="IssueItem" />
                            <Setter Property="Background"
                                    Value="{StaticResource LvItemIssues_HoverBackground}"
                                    TargetName="IssueItem" />
                            <Setter Property="Cursor"
                                    Value="Hand"
                                    TargetName="IssueItem" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- LvItemDebug -->
    <Style TargetType="ListViewItem"
           x:Key="LvItemDebug">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border x:Name="IssueItem"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding ElementName=lvDebugLocation, Path=Width}" />
                                <ColumnDefinition Width="{Binding ElementName=lvDebugLineNumber, Path=Width}" />
                                <ColumnDefinition Width="{Binding ElementName=lvDebugTime, Path=Width}" />
                                <ColumnDefinition Width="{Binding ElementName=lvDebugMessage, Path=Width}" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding DLocation}"
                                       Grid.Column="0"
                                       FontWeight="Normal"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Margin="5,0,0,0"
                                       TextTrimming="CharacterEllipsis" />

                            <TextBlock Text="{Binding DLineNumber}"
                                       Grid.Column="1"
                                       FontWeight="Normal"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Margin="5,0,0,0"
                                       TextTrimming="CharacterEllipsis" />


                            <TextBlock Text="{Binding DTime}"
                                       Grid.Column="2"
                                       FontWeight="Normal"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Margin="5,0,0,0"
                                       TextTrimming="CharacterEllipsis" />


                            <TextBlock Text="{Binding DMessage}"
                                       Grid.Column="3"
                                       FontWeight="Normal"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Margin="5,0,0,0"
                                       TextWrapping="Wrap" />



                        </Grid>

                    </Border>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- LvItemPanColors -->
    <Style TargetType="ListViewItem"
           x:Key="LvItemPanColors">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border x:Name="IssueItem"
                            BorderThickness="1"
                            Margin="2,2,12,2"
                            Background="{Binding Color}">
                        <Grid>
                            <TextBlock Text="{Binding FriendlyName}"
                                       Grid.Column="0"
                                       FontWeight="Thin"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       Margin="5,0,0,0"
                                       Padding="5"
                                       Cursor="Hand"
                                       Foreground="{Binding IsItDarkColor, Converter={StaticResource DarkColorBoolToColorConverter}}"
                                       TextTrimming="CharacterEllipsis">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="MouseDown">
                                        <i:InvokeCommandAction Command="{Binding DataContext.ItemClickedCommand, 
                                             RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListView}}}"
                                                               CommandParameter="{Binding .}" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </TextBlock>

                        </Grid>

                    </Border>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- LvItemForItemList-->
    <Style TargetType="ListViewItem"
           x:Key="LvItemForItemList">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border x:Name="Item"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding ElementName=headerItem, Path=Width}" />
                                <ColumnDefinition Width="{Binding ElementName=headerCacheMaterialName, Path=Width}" />
                            </Grid.ColumnDefinitions>



                            <!-- Item -->
                            <StackPanel VerticalAlignment="Top"
                                        Height="auto"
                                        MinHeight="25"
                                        Grid.Column="0"
                                        Margin="0,0,10,0">
                                <StackPanel Orientation="Vertical"
                                            Margin="0,0,0,0">
                                    <TextBlock Text="{Binding Item}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Foreground="{Binding StCopyExists}"
                                               TextTrimming="CharacterEllipsis"
                                               HorizontalAlignment="Right"
                                               x:Name="tbItem" />


                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,1,0,0"
                                                HorizontalAlignment="Right">


                                        <Label Content="Manufacturer set:"
                                               FontSize="8"
                                               FontWeight="Normal"
                                               Padding="0,0,4,0"
                                               x:Name="lblManufActual">
                                            <Label.Visibility>
                                                <MultiBinding StringFormat=" {0}, {1}"
                                                              Converter="{StaticResource EqualToHiddenConverter}">
                                                    <Binding ElementName="tbManufOriginal"
                                                             Path="Text" />
                                                    <Binding ElementName="tbManufActual"
                                                             Path="Text" />
                                                </MultiBinding>
                                            </Label.Visibility>
                                        </Label>
                                        <TextBlock Text="{Binding ManufName}"
                                                   x:Name="tbManufActual"
                                                   Foreground="{DynamicResource LvItemForItemList_CrimsonForeground}"
                                                   FontSize="8"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="WrapWithOverflow"
                                                   Padding="0,0,0,1">
                                            <TextBlock.Visibility>
                                                <MultiBinding StringFormat=" {0}, {1}"
                                                              Converter="{StaticResource EqualToHiddenConverter}">
                                                    <Binding ElementName="tbManufOriginal"
                                                             Path="Text" />
                                                    <Binding ElementName="tbManufActual"
                                                             Path="Text" />
                                                </MultiBinding>
                                            </TextBlock.Visibility>
                                        </TextBlock>

                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,1,0,2"
                                                HorizontalAlignment="Right">

                                        <Label Content="Original setup was:"
                                               FontSize="8"
                                               FontWeight="Normal"
                                               x:Name="lblManufOrig"
                                               Padding="8,0,4,0">
                                            <Label.Visibility>
                                                <MultiBinding StringFormat=" {0}, {1}"
                                                              Converter="{StaticResource EqualToHiddenConverter}">
                                                    <Binding ElementName="tbManufOriginal"
                                                             Path="Text" />
                                                    <Binding ElementName="tbManufActual"
                                                             Path="Text" />
                                                </MultiBinding>
                                            </Label.Visibility>
                                        </Label>
                                        <TextBlock Text="{Binding ManufName_stCopy}"
                                                   x:Name="tbManufOriginal"
                                                   Foreground="{DynamicResource LvItemForItemList_ValidLabelForeground}"
                                                   FontSize="8"
                                                   FontWeight="Normal"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="WrapWithOverflow">
                                            <TextBlock.Visibility>
                                                <MultiBinding StringFormat=" {0}, {1}"
                                                              Converter="{StaticResource EqualToHiddenConverter}">
                                                    <Binding ElementName="tbManufOriginal"
                                                             Path="Text" />
                                                    <Binding ElementName="tbManufActual"
                                                             Path="Text" />
                                                </MultiBinding>
                                            </TextBlock.Visibility>
                                        </TextBlock>

                                    </StackPanel>

                                </StackPanel>
                            </StackPanel>


                            <!-- Material & manufProc -->

                            <StackPanel Orientation="Vertical"
                                        Grid.Column="1"
                                        Margin="5,0,10,0"
                                        VerticalAlignment="Top">
                                <TextBlock Text="{Binding CacheMaterialName}"
                                           Foreground="{DynamicResource LvItemForItemList_PrimaryForeground}"
                                           FontWeight="SemiBold"
                                           TextWrapping="WrapWithOverflow"
                                           Margin="0,0,0,0"
                                           Padding="0"
                                           VerticalAlignment="Top" />


                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,2"
                                            VerticalAlignment="Bottom">
                                    <Label Content="ManufProc:"
                                           FontSize="8"
                                           FontWeight="Normal"
                                           Foreground="{DynamicResource LvItemForItemList_SecondaryForeground}"
                                           Margin="0,1,3,0"
                                           Padding="0"
                                           x:Name="lblManufProc">
                                        <Label.Visibility>
                                            <MultiBinding StringFormat=" {0}, {1}"
                                                          Converter="{StaticResource EqualToHiddenConverter}">
                                                <Binding ElementName="tbManufacturingProcessIDOriginal"
                                                         Path="Text" />
                                                <Binding ElementName="tbManufacturingProcessIDActual"
                                                         Path="Text" />
                                            </MultiBinding>
                                        </Label.Visibility>
                                    </Label>
                                    <TextBlock Text="{Binding ManufacturingProcessID}"
                                               Foreground="{DynamicResource LvItemForItemList_ErrorForeground}"
                                               FontSize="8"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Margin="0,1,0,0"
                                               TextWrapping="WrapWithOverflow"
                                               x:Name="tbManufacturingProcessIDActual">
                                        <TextBlock.Visibility>
                                            <MultiBinding StringFormat=" {0}, {1}"
                                                          Converter="{StaticResource EqualToHiddenConverter}">
                                                <Binding ElementName="tbManufacturingProcessIDOriginal"
                                                         Path="Text" />
                                                <Binding ElementName="tbManufacturingProcessIDActual"
                                                         Path="Text" />
                                            </MultiBinding>
                                        </TextBlock.Visibility>
                                    </TextBlock>

                                    <TextBlock Text="≠"
                                               Foreground="{DynamicResource LvItemForItemList_InfoForeground}"
                                               FontSize="10"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               Margin="5,-2,0,0"
                                               TextWrapping="WrapWithOverflow"
                                               x:Name="lblNotEqual">
                                        <TextBlock.Visibility>
                                            <MultiBinding StringFormat=" {0}, {1}"
                                                          Converter="{StaticResource EqualToHiddenConverter}">
                                                <Binding ElementName="tbManufacturingProcessIDOriginal"
                                                         Path="Text" />
                                                <Binding ElementName="tbManufacturingProcessIDActual"
                                                         Path="Text" />
                                            </MultiBinding>
                                        </TextBlock.Visibility>
                                    </TextBlock>

                                    <TextBlock Text="{Binding ManufacturingProcessID_stCopy}"
                                               Foreground="{DynamicResource LvItemArchives_DateLabelGreenForeground}"
                                               FontSize="8"
                                               Margin="5,0,0,0"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               TextWrapping="WrapWithOverflow"
                                               x:Name="tbManufacturingProcessIDOriginal">
                                        <TextBlock.Visibility>
                                            <MultiBinding StringFormat=" {0}, {1}"
                                                          Converter="{StaticResource EqualToHiddenConverter}">
                                                <Binding ElementName="tbManufacturingProcessIDOriginal"
                                                         Path="Text" />
                                                <Binding ElementName="tbManufacturingProcessIDActual"
                                                         Path="Text" />
                                            </MultiBinding>
                                        </TextBlock.Visibility>
                                    </TextBlock>



                                </StackPanel>

                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,0"
                                            VerticalAlignment="Bottom">
                                    <Label Content="ManufID:"
                                           FontSize="8"
                                           FontWeight="Normal"
                                           Foreground="{DynamicResource LvItemForItemList_SecondaryForeground}"
                                           Margin="0,1,3,0"
                                           Padding="0"
                                           x:Name="lblManufID">
                                        <Label.Visibility>
                                            <MultiBinding StringFormat=" {0}, {1}"
                                                          Converter="{StaticResource EqualToHiddenConverter}">
                                                <Binding ElementName="tbManufacturerIDOriginal"
                                                         Path="Text" />
                                                <Binding ElementName="tbManufacturerIDActual"
                                                         Path="Text" />
                                            </MultiBinding>
                                        </Label.Visibility>
                                    </Label>
                                    <TextBlock Text="{Binding ManufacturerID}"
                                               Foreground="{DynamicResource LvItemForItemList_ErrorForeground}"
                                               FontSize="8"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Margin="0,1,0,0"
                                               TextWrapping="WrapWithOverflow"
                                               x:Name="tbManufacturerIDOriginal">
                                        <TextBlock.Visibility>
                                            <MultiBinding StringFormat=" {0}, {1}"
                                                          Converter="{StaticResource EqualToHiddenConverter}">
                                                <Binding ElementName="tbManufacturerIDOriginal"
                                                         Path="Text" />
                                                <Binding ElementName="tbManufacturerIDActual"
                                                         Path="Text" />
                                            </MultiBinding>
                                        </TextBlock.Visibility>
                                    </TextBlock>

                                    <TextBlock Text="{Binding ManufacturerID_stCopy}"
                                               Foreground="{DynamicResource LvItemArchives_DateLabelGreenForeground}"
                                               FontSize="8"
                                               Margin="5,1,0,0"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               TextWrapping="WrapWithOverflow"
                                               x:Name="tbManufacturerIDActual">
                                        <TextBlock.Visibility>
                                            <MultiBinding StringFormat=" {0}, {1}"
                                                          Converter="{StaticResource EqualToHiddenConverter}">
                                                <Binding ElementName="tbManufacturerIDOriginal"
                                                         Path="Text" />
                                                <Binding ElementName="tbManufacturerIDActual"
                                                         Path="Text" />
                                            </MultiBinding>
                                        </TextBlock.Visibility>
                                    </TextBlock>



                                </StackPanel>
                            </StackPanel>







                        </Grid>

                    </Border>


                    <ControlTemplate.Triggers>
                        <Trigger Property="ItemsControl.AlternationIndex"
                                 Value="1">
                            <Setter TargetName="Item"
                                    Property="Background"
                                    Value="{StaticResource LvItemForItemList_AlternateBackground}" />
                        </Trigger>

                        <DataTrigger Binding="{Binding ValidateItemIntegrity}"
                                     Value="FailedToValidate">
                            <Setter TargetName="Item"
                                    Property="Background"
                                    Value="{StaticResource LvItemForItemList_FailedBackground}" />
                        </DataTrigger>

                        <DataTrigger Binding="{Binding ValidateItemIntegrity}"
                                     Value="Invalid">
                            <Setter TargetName="Item"
                                    Property="Background"
                                    Value="{StaticResource LvItemForItemList_InvalidBackground}" />
                            <Setter TargetName="tbItem"
                                    Property="Foreground"
                                    Value="{StaticResource LvItemForItemList_CrimsonForeground}" />
                        </DataTrigger>

                        <DataTrigger Binding="{Binding ValidateItemIntegrity}"
                                     Value="Valid">
                            <Setter TargetName="Item"
                                    Property="Background"
                                    Value="{StaticResource LvItemForItemList_ValidBackground}" />
                        </DataTrigger>

                        <DataTrigger Binding="{Binding ValidateItemIntegrity}"
                                     Value="ChangedItem">
                            <Setter TargetName="Item"
                                    Property="Background"
                                    Value="{StaticResource LvItemForItemList_ChangedBackground}" />
                            <Setter TargetName="tbItem"
                                    Property="Foreground"
                                    Value="{StaticResource LvItemForItemList_ChangedValueForeground}" />
                            <Setter TargetName="tbManufOriginal"
                                    Property="Visibility"
                                    Value="Collapsed" />
                            <Setter TargetName="tbManufActual"
                                    Property="Visibility"
                                    Value="Collapsed" />
                            <Setter TargetName="lblManufActual"
                                    Property="Visibility"
                                    Value="Collapsed" />
                            <Setter TargetName="lblManufOrig"
                                    Property="Content"
                                    Value="Item was changed after scan!" />
                            <Setter TargetName="lblManufOrig"
                                    Property="Foreground"
                                    Value="{StaticResource LvItemForItemList_ChangedLabelForeground}" />
                            <Setter TargetName="lblManufOrig"
                                    Property="FontWeight"
                                    Value="SemiBold" />
                            <Setter TargetName="lblManufOrig"
                                    Property="Margin"
                                    Value="0,0,0,2" />
                            <Setter TargetName="tbManufacturingProcessIDActual"
                                    Property="Visibility"
                                    Value="Collapsed" />
                            <Setter TargetName="tbManufacturingProcessIDOriginal"
                                    Property="Visibility"
                                    Value="Collapsed" />
                            <Setter TargetName="tbManufacturerIDActual"
                                    Property="Visibility"
                                    Value="Collapsed" />
                            <Setter TargetName="tbManufacturerIDOriginal"
                                    Property="Visibility"
                                    Value="Collapsed" />
                            <Setter TargetName="lblManufID"
                                    Property="Visibility"
                                    Value="Collapsed" />
                            <Setter TargetName="lblNotEqual"
                                    Property="Visibility"
                                    Value="Collapsed" />
                            <Setter TargetName="lblManufProc"
                                    Property="Visibility"
                                    Value="Collapsed" />

                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- LvItemImages -->
    <Style TargetType="ListViewItem"
           x:Key="LvItemImages">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border x:Name="Item"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="imageBorder"
                                    Margin="0"
                                    Padding="0">
                                <Image Source="{Binding Path, Converter={StaticResource StringToImageConverter}}"
                                       Tag="{Binding Path}"
                                       x:Name="image"
                                       Height="243"
                                       Width="251"
                                       Margin="4">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                            <i:InvokeCommandAction Command="{Binding DataContext.ImageClickedCommand, 
                                                                             RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListView}}}"
                                                                   CommandParameter="{Binding Path}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </Image>
                            </Border>
                        </Grid>

                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- LvItemSentOutCases -->
    <Style TargetType="ListViewItem"
           x:Key="LvItemSentOutCases">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border x:Name="Item"
                            BorderThickness="1"
                            Tag="{Binding OrderID}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding ElementName=headerIcon, Path=Width}" />
                                <ColumnDefinition Width="{Binding ElementName=headerCaseID, Path=Width}" />
                                <ColumnDefinition Width="{Binding ElementName=headerCrowns, Path=Width}" />
                                <ColumnDefinition Width="{Binding ElementName=headerAbutments, Path=Width}" />
                                <ColumnDefinition Width="{Binding ElementName=headerModels, Path=Width}" />
                                <ColumnDefinition Width="{Binding ElementName=headerSentOn, Path=Width}" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <Image Source="{Binding IconImage}"
                                       Width="30"
                                       Height="30"
                                       Margin="3,-2,2,0"
                                       Grid.Column="0"
                                       VerticalAlignment="Top" />

                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        HorizontalAlignment="Stretch">
                                <DockPanel HorizontalAlignment="Stretch"
                                           Margin="0">
                                    <TextBlock Text="{Binding OrderID}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Left"
                                               Margin="5,0,10,0"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding CommentColor}"
                                               TextTrimming="CharacterEllipsis" />

                                    <TextBlock Text="{Binding RushCaseComment}"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource LvItemForItemList_CrimsonForeground}"
                                               Margin="0,0,5,0"
                                               HorizontalAlignment="Left"
                                               Visibility="{Binding Rush, Converter={StaticResource RushToVisibleConverter}}"
                                               TextTrimming="CharacterEllipsis" />

                                    <TextBlock Text="{Binding OrderDesignedComment}"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource LvItemArchives_DateLabelGreenForeground}"
                                               Margin="0,0,5,0"
                                               Visibility="{Binding CommentIcon, Converter={StaticResource CommentIconToVisibleConverter}}"
                                               TextTrimming="CharacterEllipsis" />

                                    <TextBlock Text="{Binding RedoCaseComment}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource LvItemSentOutCases_PurpleForeground}"
                                               Margin="0,0,5,0"
                                               Visibility="{Binding Redo, Converter={StaticResource RushToVisibleConverter}}"
                                               TextTrimming="CharacterEllipsis" />

                                    <TextBlock Text="{Binding ScrewRetainedCaseComment}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource LvItemArchives_PanValueForeground}"
                                               Margin="0,0,5,0"
                                               Visibility="{Binding ScrewRetained, Converter={StaticResource BoolToVisibilityConverter}}"
                                               TextTrimming="CharacterEllipsis" />

                                </DockPanel>

                                <TextBlock Text="{Binding Items}"
                                           VerticalAlignment="Center"
                                           Margin="5,-2,10,0"
                                           FontSize="8"
                                           Foreground="{DynamicResource LvItemSentOutCases_GrayForeground}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Comment}"
                                           VerticalAlignment="Center"
                                           Margin="5,-2,10,0"
                                           FontSize="8"
                                           Foreground="{DynamicResource LvItemSentOutCases_IndianRedForeground}"
                                           Visibility="{Binding Comment, Converter={StaticResource TextToVisibilityConverter}}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding CommentIn3Shape}"
                                           VerticalAlignment="Center"
                                           Margin="5,-2,10,0"
                                           FontSize="8"
                                           Foreground="{DynamicResource LvItemSentOutCases_MediumOrchidForeground}"
                                           Cursor="Hand"
                                           Visibility="{Binding CommentIn3Shape, Converter={StaticResource TextToVisibilityConverter}}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="Wrap" />

                                <TextBlock Text="{Binding RushForMorningComment}"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold"
                                           Margin="5,-2,10,0"
                                           FontSize="8"
                                           Foreground="{DynamicResource LvItemForItemList_CrimsonForeground}"
                                           Visibility="{Binding Rush, Converter={StaticResource RushToVisibleConverter}}"
                                           TextTrimming="CharacterEllipsis" />

                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Top"
                                        HorizontalAlignment="Left"
                                        Grid.Column="2"
                                        Margin="6,-2,0,0"
                                        Visibility="{Binding Crowns, Converter={StaticResource TextToVisibilityConverter}}">
                                <Grid Visibility="{Binding ScrewRetained, Converter={StaticResource BoolToInverseVisibilityConverter}}">
                                    <Image Source="\Images\SentOutCases\crown.png"
                                           Grid.Column="4"
                                           Width="18"
                                           Height="18"
                                           Margin="0,0,2,0" />
                                </Grid>
                                <Grid Visibility="{Binding ScrewRetained, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Image Source="\Images\SentOutCases\screwretained.png"
                                           Grid.Column="4"
                                           Width="18"
                                           Height="18"
                                           Margin="0,0,2,0" />
                                </Grid>
                                <TextBlock Text="{Binding Crowns}"
                                           Grid.Column="2"
                                           FontSize="16"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Top"
                                        HorizontalAlignment="Left"
                                        Margin="4,-2,0,0"
                                        Grid.Column="3">
                                <Image Source="\Images\SentOutCases\abutment.png"
                                       Grid.Column="4"
                                       Width="18"
                                       Height="18"
                                       Margin="0,2,-1,0"
                                       Visibility="{Binding Abutments, Converter={StaticResource TextToVisibilityConverter}}" />
                                <TextBlock Text="{Binding Abutments}"
                                           Grid.Column="3"
                                           FontSize="16"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </StackPanel>

                            <Image Source="\Images\SentOutCases\models.png"
                                   Grid.Column="4"
                                   VerticalAlignment="Top"
                                   HorizontalAlignment="Center"
                                   Margin="0,1,0,0"
                                   Width="18"
                                   Height="18"
                                   Visibility="{Binding Models, Converter={StaticResource TextToVisibilityConverter}}" />

                            <StackPanel Grid.Column="5"
                                        VerticalAlignment="Top"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="{Binding SentOn, Converter={StaticResource RemoveFirstCharFromStringIfItsZConverter}}" />
                                <TextBlock Text="{Binding OriginalSentOnForChangedSentOn, Converter={StaticResource RemoveFirstCharFromStringIfItsZConverter}}"
                                           FontSize="10"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding CommentColor}">
                                    <TextBlock.Visibility>
                                        <MultiBinding StringFormat=" {0}, {1}"
                                                      Converter="{StaticResource EqualToCollapsedVisibilityConverter}">
                                            <Binding Path="SentOn" />
                                            <Binding Path="OriginalSentOnForChangedSentOn" />
                                        </MultiBinding>
                                    </TextBlock.Visibility>
                                </TextBlock>
                            </StackPanel>

                        </Grid>

                    </Border>


                    <ControlTemplate.Triggers>
                        <!--Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter Property="BorderBrush"
                                    Value="{DynamicResource LvItemSentOutCases_HoverBorderBrush}"
                                    TargetName="Item" />
                            <Setter Property="Background"
                                    Value="{DynamicResource LvItemSentOutCases_HoverBackgroundAlt}"
                                    TargetName="Item" />
                            <Setter Property="Cursor"
                                    Value="Arrow"
                                    TargetName="Item" />
                        </Trigger-->
                        <Trigger Property="ItemsControl.AlternationIndex"
                                 Value="1">
                            <Setter TargetName="Item"
                                    Property="Background"
                                    Value="{StaticResource LvItemSentOutCases_AlternateBackground}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- LvItemAccountInfo -->
    <Style TargetType="ListViewItem"
           x:Key="LvItemAccountInfo">
        <Setter Property="Background"
                Value="{DynamicResource LvItemAccountInfo_ItemBackground}" />
        <Setter Property="BorderThickness"
                Value="0" />
        <Setter Property="HorizontalContentAlignment"
                Value="Stretch" />
        <Setter Property="Padding"
                Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border x:Name="AccountInfoItem"
                            Tag="{Binding Credentials.Password}"
                            Margin="0,4"
                            CornerRadius="9"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource LvItemAccountInfo_CardBorderBrush}"
                            Background="{DynamicResource LvItemAccountInfo_CardBackground}"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource LvItemAccountInfo_Shadow_Cl}"
                                              BlurRadius="14"
                                              ShadowDepth="0"
                                              Opacity="0.1" />
                        </Border.Effect>
                        <Grid MinHeight="72"
                              Margin="0,0,8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="240" />
                                <ColumnDefinition Width="*" MinWidth="280" />
                                <ColumnDefinition Width="172" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    CornerRadius="9,0,0,9"
                                    Background="{Binding Color, Converter={StaticResource ColorToPastelAccentConverter}}" />

                            <Border Grid.Column="1"
                                    Width="36"
                                    Height="36"
                                    CornerRadius="7"
                                    Background="{DynamicResource LvItemAccountInfo_IconBackground}"
                                    BorderBrush="{DynamicResource LvItemAccountInfo_IconBorderBrush}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <Image Source="{Binding ApplicationName, Converter={StaticResource AppNameToIconConverter}}"
                                       Width="22"
                                       Height="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Margin="4,0,12,0">
                                <TextBlock Text="{Binding FriendlyName}"
                                           Foreground="{DynamicResource LvItemAccountInfo_TitleForeground}"
                                           FontWeight="SemiBold"
                                           FontSize="15"
                                           TextTrimming="CharacterEllipsis" />

                                <Border Margin="0,5,0,0"
                                        Padding="8,2"
                                        HorizontalAlignment="Left"
                                        CornerRadius="5"
                                        Background="{DynamicResource LvItemAccountInfo_BadgeBackground}"
                                        BorderBrush="{DynamicResource LvItemAccountInfo_BadgeBorderBrush}"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding SubCategory}"
                                               Foreground="{DynamicResource LvItemAccountInfo_BadgeForeground}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                </Border>
                            </StackPanel>

                            <Border Grid.Column="3"
                                    Margin="0,10,8,10"
                                    Padding="10,8"
                                    CornerRadius="8"
                                    Background="{DynamicResource LvItemAccountInfo_IconBackground}"
                                    BorderBrush="{DynamicResource LvItemAccountInfo_IconBorderBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" MinWidth="120" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Image Grid.Row="0"
                                           Source="\Images\AccountInfoIcons\user.png"
                                           Width="12"
                                           Height="12"
                                           Margin="0,0,0,6"
                                           Opacity="0.75" />

                                    <TextBlock Text="{Binding Credentials.UserName}"
                                               Grid.Row="0"
                                               Grid.Column="1"
                                               FontSize="12"
                                               Foreground="{DynamicResource LvItemAccountInfo_TitleForeground}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,8,6" />

                                    <Image Grid.Row="1"
                                           Source="\Images\AccountInfoIcons\key.png"
                                           Width="12"
                                           Height="12"
                                           Opacity="0.75" />

                                    <TextBlock Text="------"
                                               Tag="{Binding Credentials.Password}"
                                               Grid.Row="1"
                                               Grid.Column="1"
                                               FontSize="12"
                                               FontFamily="Consolas"
                                               Foreground="{DynamicResource LvItemAccountInfo_BadgeForeground}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,8,0" />

                                    <Button Grid.Row="0"
                                            Grid.Column="2"
                                            Content="Copy user /email"
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource LvItemAccountInfo_BadgeForeground}"
                                            Margin="0,0,4,6"
                                            Padding="8,3"
                                            Width="110"
                                            Cursor="Hand"
                                            Command="{Binding DataContext.CopyUserNameToClipboardCommand,
                                                              RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListView}}}"
                                            CommandParameter="{Binding Credentials.UserName}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="CopyUserBtn"
                                                        CornerRadius="6"
                                                        Background="{DynamicResource LvItemAccountInfo_BadgeBackground}"
                                                        BorderBrush="{DynamicResource LvItemAccountInfo_BadgeBorderBrush}"
                                                        BorderThickness="1"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver"
                                                             Value="True">
                                                        <Setter TargetName="CopyUserBtn"
                                                                Property="Background"
                                                                Value="{StaticResource LvItemAccountInfo_CopyBtnHoverBackground}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Button Grid.Row="1"
                                            Grid.Column="2"
                                            Content="Copy password "
                                            HorizontalAlignment="Left"
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource LvItemAccountInfo_BadgeForeground}"
                                            Margin="0,0,4,0"
                                            Padding="8,3"
                                            Width="110"
                                            Cursor="Hand"
                                            Command="{Binding DataContext.CopyPasswordToClipboardCommand,
                                                              RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListView}}}"
                                            CommandParameter="{Binding Credentials.Password}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="CopyPassBtn"
                                                        CornerRadius="6"
                                                        Background="{DynamicResource LvItemAccountInfo_BadgeBackground}"
                                                        BorderBrush="{DynamicResource LvItemAccountInfo_BadgeBorderBrush}"
                                                        BorderThickness="1"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver"
                                                             Value="True">
                                                        <Setter TargetName="CopyPassBtn"
                                                                Property="Background"
                                                                Value="{StaticResource LvItemAccountInfo_CopyBtnHoverBackground}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Button Content="Show password"
                                            Grid.Row="1"
                                            Grid.Column="3"
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource LvItemAccountInfo_ShowPassForeground}"
                                            Padding="8,3"
                                            Cursor="Hand"
                                            Tag="{Binding Credentials.Password}"
                                            Click="AccountInfosShowPassword_Button_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="ShowPassBtn"
                                                        CornerRadius="6"
                                                        Background="{DynamicResource LvItemAccountInfo_ShowPassBackground}"
                                                        BorderBrush="{DynamicResource LvItemAccountInfo_ShowPassBorderBrush}"
                                                        BorderThickness="1"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver"
                                                             Value="True">
                                                        <Setter TargetName="ShowPassBtn"
                                                                Property="Background"
                                                                Value="{StaticResource LvItemAccountInfo_ShowPassBorderBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>

                            <Button Grid.Column="4"
                                    Height="36"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding ApplicationName, Converter={StaticResource EmptyAppNameToVisibleConverter}}"
                                    Command="{Binding DataContext.OpenWebsiteCommand,
                                              RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListView}}}"
                                    CommandParameter="{Binding Website}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="OpenSiteBtn"
                                                CornerRadius="7"
                                                Padding="12,0"
                                                BorderThickness="1"
                                                BorderBrush="{DynamicResource LvItemAccountInfo_ActionBorderBrush}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0"
                                                                     EndPoint="1,1">
                                                    <GradientStop Color="{DynamicResource LvItemAccountInfo_ActionGradientStart_Cl}"
                                                                  Offset="0" />
                                                    <GradientStop Color="{DynamicResource LvItemAccountInfo_ActionGradientEnd_Cl}"
                                                                  Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver"
                                                     Value="True">
                                                <Setter TargetName="OpenSiteBtn"
                                                        Property="Background"
                                                        Value="{StaticResource LvItemAccountInfo_CopyBtnHoverBackground}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">
                                        <Image Source="{Binding ApplicationName, Converter={StaticResource AppNameToIconConverter}}"
                                               Width="16"
                                               Height="16"
                                               Margin="0,0,8,0" />
                                        <TextBlock Text="Open website"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource LvItemAccountInfo_BadgeForeground}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <Button Grid.Column="4"
                                    Height="36"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding ApplicationName, Converter={StaticResource EmptyAppNameToCollapsedConverter}}"
                                    Command="{Binding DataContext.StartApplicationCommand,
                                                      RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListView}}}"
                                    CommandParameter="{Binding ApplicationPath}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="StartAppBtn"
                                                CornerRadius="7"
                                                Padding="12,0"
                                                BorderThickness="1"
                                                BorderBrush="{DynamicResource LvItemAccountInfo_ActionBorderBrush}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0"
                                                                     EndPoint="1,1">
                                                    <GradientStop Color="{DynamicResource LvItemAccountInfo_ActionGradientStart_Cl}"
                                                                  Offset="0" />
                                                    <GradientStop Color="{DynamicResource LvItemAccountInfo_ActionGradientEnd_Cl}"
                                                                  Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver"
                                                     Value="True">
                                                <Setter TargetName="StartAppBtn"
                                                        Property="Background"
                                                        Value="{StaticResource LvItemAccountInfo_CopyBtnHoverBackground}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">
                                        <Image Source="{Binding ApplicationName, Converter={StaticResource AppNameToIconConverter}}"
                                               Width="16"
                                               Height="16"
                                               Margin="0,0,8,0" />
                                        <TextBlock Text="Start application"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource LvItemAccountInfo_BadgeForeground}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="AccountInfoItem"
                                    Property="BorderBrush"
                                    Value="{StaticResource LvItemAccountInfo_HoverBorderBrush}" />
                            <Setter TargetName="AccountInfoItem"
                                    Property="Background"
                                    Value="{StaticResource LvItemAccountInfo_HoverBackground}" />
                        </Trigger>
                        <Trigger Property="IsSelected"
                                 Value="True">
                            <Setter TargetName="AccountInfoItem"
                                    Property="BorderBrush"
                                    Value="{StaticResource LvItemAccountInfo_SelectedBorderBrush}" />
                            <Setter TargetName="AccountInfoItem"
                                    Property="Background"
                                    Value="{StaticResource LvItemAccountInfo_SelectedBackground}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- LvSentHealthReports -->
    <Style TargetType="ListViewItem"
           x:Key="LvSentHealthReports">
        <Setter Property="Background"
                Value="{DynamicResource LvSentHealthReports_ItemBackground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border x:Name="Item"
                            BorderThickness="1">

                        <Grid Margin="1,0,1,6"
                              HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition  Width="{Binding ElementName=serviceHealthListTaskName, Path=Width}" />
                            </Grid.ColumnDefinitions>

                            <Grid HorizontalAlignment="Right">
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition Height="auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="28" />
                                </Grid.ColumnDefinitions>



                                <TextBlock Text="{Binding TaskName}"
                                           Foreground="{Binding ForeColor}"
                                           HorizontalAlignment="Right"
                                           FontWeight="Normal"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,0"
                                           Padding="10,2,0,4"
                                           Grid.Column="0" />

                                <StackPanel Grid.Row="1"
                                            Grid.Column="0"
                                            HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding ServiceStatus}"
                                               Foreground="{DynamicResource LvSentHealthReports_StatusForeground}"
                                               FontWeight="Normal"
                                               FontSize="9"
                                               HorizontalAlignment="Right"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,-7,0,0"
                                               Padding="11,2,0,4" />

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Last report:"
                                                   Foreground="{DynamicResource LvSentHealthReports_LabelForeground}"
                                                   FontWeight="Normal"
                                                   FontSize="8"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="5,-6,0,0"
                                                   Padding="2,2,2,0" />
                                        <TextBlock Text="{Binding LastReport, Converter={StaticResource DateToMinutesConverter}}"
                                                   Foreground="{DynamicResource LvSentHealthReports_TimestampForeground}"
                                                   FontWeight="Normal"
                                                   FontSize="8"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,-6,0,0"
                                                   Padding="2,2,2,0" />
                                    </StackPanel>

                                </StackPanel>

                                <Image Source="{Binding ServiceStatus, Converter={StaticResource ServiceStatusToIconConverter}}"
                                       Margin="4,2,-6,0"
                                       Grid.RowSpan="2"
                                       Width="28"
                                       Height="28"
                                       VerticalAlignment="Top"
                                       Grid.Column="1" />
                            </Grid>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- LvItemMainMenu -->
    <Style TargetType="ListViewItem"
           x:Key="LvItemMainMenu">
        <Setter Property="Background"
                Value="{DynamicResource LvItemMainMenu_ItemBackground}" />
        <Setter Property="Template">
