    <!-- LvItemFolderSubscription -->
    <Style TargetType="ListViewItem"
           x:Key="LvItemFolderSubscription">

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border x:Name="Item"
                            BorderThickness="1">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseDown">
                                <i:InvokeCommandAction Command="{Binding DataContext.FsItemClickedCommand, 
                                                                 RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListView}}}"
                                                       CommandParameter="{Binding .}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding ElementName=fsIcon, Path=Width, FallbackValue=25}" />
                                <ColumnDefinition Width="{Binding ElementName=fsName, Path=Width, FallbackValue=290}" />
                                <ColumnDefinition Width="{Binding ElementName=fsLastModified, Path=Width, FallbackValue=132}" />
                                <ColumnDefinition Width="{Binding ElementName=fsAge, Path=Width, FallbackValue=64}" />
                            </Grid.ColumnDefinitions>


                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="22"
                                         Height="22"
                                         Margin="0,0,0,0"
                                         Grid.Column="0"
                                         VerticalAlignment="Center">
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="/Images/folder.png" />
                                    </Ellipse.Fill>
                                </Ellipse>

                            </StackPanel>

                            <TextBlock Text="{Binding FolderName}"
                                       Grid.Column="1"
                                       FontWeight="Normal"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="{Binding AgeForColoring, Converter={StaticResource AgeToColorConverter}}"
                                       Margin="5,0,0,0"
                                       TextTrimming="CharacterEllipsis" />




                            <TextBlock Text="{Binding LastModified}"
                                       Grid.Column="2"
                                       FontWeight="Normal"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="{Binding AgeForColoring, Converter={StaticResource AgeToColorConverter}}"
                                       Margin="5,0,0,0"
                                       TextTrimming="CharacterEllipsis" />

                            <TextBlock Text="{Binding Age}"
                                       Grid.Column="3"
                                       FontWeight="Normal"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="{Binding AgeForColoring, Converter={StaticResource AgeToColorConverter}}"
                                       Margin="5,0,0,0"
                                       TextTrimming="CharacterEllipsis" />



                        </Grid>

                    </Border>


                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter Property="BorderBrush"
                                    Value="{StaticResource LvItemFolderSubscription_HoverBorderBrush}"
                                    TargetName="Item" />
                            <Setter Property="Background"
                                    Value="{StaticResource LvItemFolderSubscription_HoverBackgroundAlt}"
                                    TargetName="Item" />
                            <Setter Property="Cursor"
                                    Value="Hand"
                                    TargetName="Item" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>


    </Style>

    <!-- LvItemImportHistory -->
    <Style TargetType="ListViewItem"
           x:Key="LvItemImportHistory">
        <Setter Property="Background"
                Value="{DynamicResource LvItemImportHistory_ItemBackground}" />
        <Setter Property="BorderThickness"
                Value="0" />
        <Setter Property="HorizontalContentAlignment"
                Value="Stretch" />
        <Setter Property="Padding"
                Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border x:Name="Item"
                            Margin="4,3"
                            Padding="0"
                            CornerRadius="9"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource LvItemImportHistory_CardBorderBrush}"
                            Background="{DynamicResource LvItemImportHistory_CardBackground}"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource LvItemImportHistory_Shadow_Cl}"
                                              BlurRadius="14"
                                              ShadowDepth="0"
                                              Opacity="0.12" />
                        </Border.Effect>
                        <Grid MinHeight="64"
                              Margin="0,0,8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    CornerRadius="9,0,0,9"
                                    Background="{DynamicResource LvItemImportHistory_AccentBackground}" />

                            <core:OutlinedTextBlock Grid.Column="1"
                                                    Stroke="{Binding DateTime, Converter={StaticResource OrderByToColorConverter}}"
                                                    StrokePosition="Outside"
                                                    FontSize="24"
                                                    FontWeight="SemiBold"
                                                    Fill="{DynamicResource LvItemImportHistory_OrderIdFill}"
                                                    StrokeThickness="2"
                                                    Text="{Binding OrderID}"
                                                    VerticalAlignment="Center"
                                                    Margin="12,0,14,0" />

                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Margin="0,6,12,6">
                                <core:OutlinedTextBlock Stroke="{DynamicResource LvItemImportHistory_EventStroke}"
                                                        StrokePosition="Outside"
                                                        FontSize="11"
                                                        FontWeight="SemiBold"
                                                        Fill="{DynamicResource LvItemImportHistory_PrimaryForeground}"
                                                        VerticalAlignment="Center"
                                                        StrokeThickness="0.5"
                                                        Text="{Binding Event}"
                                                        Margin="0,0,0,2" />

                                <core:OutlinedTextBlock Stroke="{DynamicResource LvItemImportHistory_NameStroke}"
                                                        StrokePosition="Outside"
                                                        FontSize="20"
                                                        FontWeight="SemiBold"
                                                        Fill="{DynamicResource LvItemImportHistory_NameFill}"
                                                        VerticalAlignment="Center"
                                                        StrokeThickness="0.85"
                                                        Text="{Binding FriendlyName}" />
                            </StackPanel>

                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right"
                                        Margin="0,0,4,0">
                                <core:OutlinedTextBlock Stroke="{Binding DateTime, Converter={StaticResource AgeToGlowForAgeConverter}}"
                                                        StrokePosition="Outside"
                                                        FontSize="20"
                                                        FontWeight="SemiBold"
                                                        Fill="{DynamicResource LvItemImportHistory_PrimaryForeground}"
                                                        VerticalAlignment="Center"
                                                        StrokeThickness="1"
                                                        Text="{Binding Age}"
                                                        Margin="0,0,12,0" />

                                <core:OutlinedTextBlock Stroke="{Binding DateTime, Converter={StaticResource AgeToGlowConverter}}"
                                                        StrokePosition="Outside"
                                                        FontSize="30"
                                                        FontWeight="SemiBold"
                                                        Fill="{DynamicResource LvItemImportHistory_PrimaryForeground}"
                                                        StrokeThickness="2"
                                                        Text="{Binding ImportTime}"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Right" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="Item"
                                    Property="BorderBrush"
                                    Value="{StaticResource LvItemImportHistory_HoverBorderBrush}" />
                            <Setter TargetName="Item"
                                    Property="Background"
                                    Value="{StaticResource LvItemImportHistory_HoverBackground}" />
                        </Trigger>
                        <Trigger Property="IsSelected"
                                 Value="True">
                            <Setter TargetName="Item"
                                    Property="BorderBrush"
                                    Value="{StaticResource LvItemImportHistory_SelectedBorderBrush}" />
                            <Setter TargetName="Item"
                                    Property="Background"
                                    Value="{StaticResource LvItemImportHistory_SelectedBackground}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- LvItemExportHistory -->
    <Style TargetType="ListViewItem"
           x:Key="LvItemExportHistory">

        <Setter Property="Template">
