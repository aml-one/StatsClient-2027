    <!-- LvItemArchives -->
    <Style TargetType="ListViewItem"
           x:Key="LvItemArchives">
        <Setter Property="Background"
                Value="{DynamicResource LvItemArchives_ItemBackground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border x:Name="Item"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource LvItemArchives_BorderBrush}"
                            Background="{DynamicResource LvItemArchives_Background}"
                            Padding="2"
                            CornerRadius="5"
                            Margin="3,2,0,3">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding ElementName=archeaderIcon, Path=Width}" />
                                <ColumnDefinition Width="{Binding ElementName=archeaderCaseID, Path=Width}" />
                                <ColumnDefinition Width="{Binding ElementName=archeaderButtons, Path=Width}" />
                                <ColumnDefinition Width="{Binding ElementName=archeaderDesigner, Path=Width}" />
                                <ColumnDefinition Width="{Binding ElementName=archeaderYear, Path=Width}" />
                                <ColumnDefinition Width="{Binding ElementName=archeaderCustomer, Path=Width}" />
                                <ColumnDefinition Width="{Binding ElementName=archeaderDates, Path=Width}" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>


                            <Image Source="{Binding Icon}"
                                   Width="26"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Top"
                                   Margin="0,0,2,0"
                                   Grid.Column="0"
                                   Grid.RowSpan="2" />


                            <TextBlock Text="{Binding OrderID}"
                                       FontSize="14"
                                       Grid.Column="1"
                                       Grid.Row="0" />

                            <StackPanel Grid.Column="1"
                                        Grid.Row="1">

                                <TextBlock Text="{Binding Items}"
                                           FontSize="10"
                                           HorizontalAlignment="Left"
                                           TextWrapping="Wrap"
                                           Width="450"
                                           Foreground="{DynamicResource LvItemArchives_ItemsForeground}" />

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="PanNr: "
                                               FontSize="11"
                                               Foreground="{DynamicResource LvItemArchives_PanLabelForeground}" />
                                    <TextBlock Text="{Binding PanNumber}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource LvItemArchives_PanValueForeground}" />
                                </StackPanel>

                                <TextBlock Text="{Binding BaseFolder}"
                                           FontSize="8"
                                           Cursor="Hand"
                                           Margin="-5,0,0,0"
                                           TextWrapping="Wrap"
                                           Width="450"
                                           Foreground="{DynamicResource LvItemArchives_FolderForeground}">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="PreviewMouseDown">
                                            <i:InvokeCommandAction Command="{Binding DataContext.ArchivesBaseFolderItemClickedCommand, 
            RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListView}}}"
                                                                   CommandParameter="{Binding .}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </TextBlock>

                                <TextBlock Text="{Binding ReasonIsDead}"
                                           FontSize="10"
                                           Foreground="{DynamicResource LvItemForItemList_ErrorForeground}" />
                            </StackPanel>


                            <!-- Buttons -->
                            <StackPanel Grid.Column="2"
                                        Grid.RowSpan="2"
                                        VerticalAlignment="Top"
                                        d:Visibility="Visible"
                                        Visibility="Hidden"
                                        x:Name="arctsButtonPanel">
                                <StackPanel HorizontalAlignment="Center"
                                            Cursor="Hand"
                                            d:Visibility="Visible"
                                            Visibility="{Binding ReasonIsDead, Converter={StaticResource EmptyTextToVisibleConverter}}"
