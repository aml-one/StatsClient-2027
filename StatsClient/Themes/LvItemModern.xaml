                                <ColumnDefinition  Width="{Binding ElementName=mainMenuItemIcon, Path=Width}" />
                                <ColumnDefinition  Width="{Binding ElementName=mainMenuItemText, Path=Width}" />
                            </Grid.ColumnDefinitions>



                            <Image Source="{Binding Icon}"
                                   Margin="0,2,0,0"
                                   Width="16"
                                   Height="16"
