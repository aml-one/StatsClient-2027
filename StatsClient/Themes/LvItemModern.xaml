                            <Setter Property="Background"
                                    Value="{StaticResource LvItemMainMenu_HoverBackground}"
                                    TargetName="Item" />
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

