                Value="1" />
        
        <Setter Property="Cursor"
                Value="Hand" />


        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid Background="{TemplateBinding Background}">
                            <ContentPresenter x:Name="MyContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <Trigger Property="IsEnabled"
                     Value="False">
                <Setter Property="Background"
                        Value="{StaticResource VitaButtonBackgroundDark}" />
                <Setter Property="Foreground"
                        Value="{StaticResource VitaButtonBorderLight}" />
                <Setter Property="BorderBrush"
                        Value="{StaticResource VitaButtonForegroundMid}" />
                <Setter Property="Button.Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="{StaticResource BlackColor_Cl}"
                                          Direction="320"
                                          ShadowDepth="3"
                                          BlurRadius="5"
                                          Opacity="0.15" />
                    </Setter.Value>
                </Setter>
            </Trigger>

            <Trigger Property="IsMouseOver"
                     Value="True">
                <Setter Property="Background"
                        Value="{StaticResource VitaButtonAccentGold}" />
                <Setter Property="Foreground"
                        Value="{StaticResource BlackColor}" />
                <Setter Property="BorderBrush"
                        Value="{StaticResource NamedYellow}" />
                
                <Setter Property="Button.Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="{StaticResource BlackColor_Cl}"
                                          Direction="320"
                                          ShadowDepth="3"
                                          BlurRadius="5"
                                          Opacity="0.5" />
                    </Setter.Value>
                </Setter>
            </Trigger>
            
            <Trigger Property="IsFocused"
                     Value="True">
                <Setter Property="Background"
                        Value="{StaticResource VitaButtonHoverGray}" />
                <Setter Property="Foreground"
                        Value="{StaticResource LightTextColor}" />
                <Setter Property="BorderBrush"
                        Value="{StaticResource LightTextColor}" />
            </Trigger>
        </Style.Triggers>
    </Style>


