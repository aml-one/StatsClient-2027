                                    Value="{StaticResource TabLegacyForegroundDisabled}" />
                            <Setter TargetName="Border"
                                    Property="BorderBrush"
                                    Value="{StaticResource TabLegacyForegroundHover}" />
                            <Setter Property="Margin"
                                    Value="0,0,0,0" />
                            <Setter Property="Foreground"
