                                    Property="Background"
                                    Value="ForestGreen" />
                            <Setter TargetName="Border"
                                    Property="BorderBrush"
                                    Value="{StaticResource VitaButtonBorderLight}" />
                            <Setter Property="Margin"
                                    Value="0,0,0,0" />
                            <Setter Property="Foreground"
                                    Value="{StaticResource NamedWhiteSmoke}" />
                        </Trigger>

                        <Trigger Property="IsSelected"
